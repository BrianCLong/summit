{
  "name": "summit-root",
  "version": "4.2.3",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "build": "pnpm -r --filter=!./apps/e2e build",
    "test": "pnpm -r --filter=!./apps/e2e test",
    "test:unit": "pnpm -r --filter=!./apps/e2e test:unit",
    "test:integration": "pnpm -r --filter=!./apps/e2e test:integration",
    "test:e2e": "pnpm --filter ./apps/e2e test",
    "test:security": "echo 'Running security tests...' && pytest tests/test_precision_flow_policy.py tests/test_detectors_deny_by_default.py",
    "lint": "pnpm -r --filter=!./apps/e2e lint",
    "dev": "pnpm -r --parallel --filter=!./apps/e2e dev",
    "clean": "pnpm -r --parallel exec rm -rf dist node_modules coverage",
    "verify:runtime": "node scripts/verify-runtime-env.js",
    "compliance:antigravity": "pnpm run ci:docs-governance",
    "ci:docs-governance": "node scripts/ci/verify_governance_docs.mjs",
    "lint:release-policy": "node scripts/release/validate-release-policy.mjs"
  },
  "pnpm": {
    "overrides": {
      "nanoid": "^3.3.7"
    }
  },
  "devDependencies": {
    "@types/node": "^20.11.24",
    "typescript": "^5.3.3",
    "vitest": "^1.3.1",
    "rimraf": "^5.0.5",
    "pnpm": "^10.0.0"
  },
  "dependencies": {
    "zod": "^3.22.4"
  },
  "pnpm": {
    "overrides": {
      "nanoid": "^3.3.7"
    }
  }
}
