{
  "name": "summit-monorepo",
  "version": "4.2.3",
  "private": true,
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "prepare": "husky install",
    "postinstall": "rm -rf node_modules/@types/hapi__catbox node_modules/@types/hapi__shot"
  },
  "devDependencies": {
    "@changesets/cli": "2.27.1",
    "@turbo/gen": "1.12.4",
    "husky": "9.0.11",
    "prettier": "3.2.5",
    "turbo": "1.12.4",
    "typescript": "5.4.5"
  },
  "dependencies": {
    "nanoid": "3.3.7"
  },
  "pnpm": {
    "overrides": {
      "nanoid": "3.3.7",
      "entities": "4.5.0"
    }
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*",
    "libs/*",
    "client",
    "server"
  ]
}
