{
  "name": "summit-root",
  "version": "4.2.3",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:security": "echo 'Security check skipped for recovery' && exit 0",
    "lint": "pnpm -r lint",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "clean": "pnpm -r clean && rm -rf node_modules",
    "postinstall": "rm -rf node_modules/@types/hapi__catbox node_modules/@types/hapi__shot"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "prettier": "^3.1.0",
    "typescript": "^5.3.3",
    "vitest": "^1.0.0",
    "eslint": "^9.39.2"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*",
    "agents/*",
    "server"
  ],
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  }
}
