{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://summit.dev/schemas/run_plan.schema.json",
  "type": "object",
  "required": ["goal", "constraints", "acceptance_criteria", "risks", "non_goals"],
  "properties": {
    "goal": {"type": "string", "minLength": 1},
    "constraints": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "acceptance_criteria": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "risks": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "non_goals": {"type": "array", "items": {"type": "string"}, "minItems": 1}
  },
  "additionalProperties": false
}
