digraph EvidenceGraph {
  rankdir=LR;
  node [fontname="Helvetica,Arial,sans-serif", margin=0.2];
  edge [fontname="Helvetica,Arial,sans-serif", fontsize=10];
  bgcolor="#f8fafc";

  "group_summit_evidence_examples" [label="Evidence Bundle\nexamples\n(summit/evidence/examples)", shape="folder", style="filled", fillcolor="#e2e8f0"];
  "report_summit_evidence_examples" [label="report.json", shape="note", style="filled", fillcolor="#bfdbfe"];
  "metrics_summit_evidence_examples" [label="metrics.json", shape="component", style="filled", fillcolor="#fecaca"];
  "stamp_summit_evidence_examples" [label="stamp.json", shape="tab", style="filled", fillcolor="#fef08a"];
  "group_summit_evidence_fixtures_fail_bundle_evidence" [label="Evidence Bundle\nevidence\n(summit/evidence/fixtures/fail_bundle/evidence)", shape="folder", style="filled", fillcolor="#e2e8f0"];
  "report_summit_evidence_fixtures_fail_bundle_evidence" [label="report.json", shape="note", style="filled", fillcolor="#bfdbfe"];
  "group_summit_evidence_fixtures_pass_bundle_evidence" [label="Evidence Bundle\nevidence\n(summit/evidence/fixtures/pass_bundle/evidence)", shape="folder", style="filled", fillcolor="#e2e8f0"];
  "report_summit_evidence_fixtures_pass_bundle_evidence" [label="report.json", shape="note", style="filled", fillcolor="#bfdbfe"];
  "metrics_summit_evidence_fixtures_pass_bundle_evidence" [label="metrics.json", shape="component", style="filled", fillcolor="#fecaca"];
  "stamp_summit_evidence_fixtures_pass_bundle_evidence" [label="stamp.json", shape="tab", style="filled", fillcolor="#fef08a"];
  "group_summit_evidence_templates" [label="Evidence Bundle\ntemplates\n(summit/evidence/templates)", shape="folder", style="filled", fillcolor="#e2e8f0"];
  "report_summit_evidence_templates" [label="report.json", shape="note", style="filled", fillcolor="#bfdbfe"];
  "metrics_summit_evidence_templates" [label="metrics.json", shape="component", style="filled", fillcolor="#fecaca"];
  "stamp_summit_evidence_templates" [label="stamp.json", shape="tab", style="filled", fillcolor="#fef08a"];
  "group_summit_evidence_templates_keel_arch" [label="Evidence Bundle\nkeel-arch\n(summit/evidence/templates/keel-arch)", shape="folder", style="filled", fillcolor="#e2e8f0"];
  "report_summit_evidence_templates_keel_arch" [label="report.json", shape="note", style="filled", fillcolor="#bfdbfe"];
  "metrics_summit_evidence_templates_keel_arch" [label="metrics.json", shape="component", style="filled", fillcolor="#fecaca"];
  "stamp_summit_evidence_templates_keel_arch" [label="stamp.json", shape="tab", style="filled", fillcolor="#fef08a"];
  "group_summit_evidence_templates_keel_bench" [label="Evidence Bundle\nkeel-bench\n(summit/evidence/templates/keel-bench)", shape="folder", style="filled", fillcolor="#e2e8f0"];
  "report_summit_evidence_templates_keel_bench" [label="report.json", shape="note", style="filled", fillcolor="#bfdbfe"];
  "metrics_summit_evidence_templates_keel_bench" [label="metrics.json", shape="component", style="filled", fillcolor="#fecaca"];
  "stamp_summit_evidence_templates_keel_bench" [label="stamp.json", shape="tab", style="filled", fillcolor="#fef08a"];
  "group_summit_evidence_templates_keel_dscl" [label="Evidence Bundle\nkeel-dscl\n(summit/evidence/templates/keel-dscl)", shape="folder", style="filled", fillcolor="#e2e8f0"];
  "report_summit_evidence_templates_keel_dscl" [label="report.json", shape="note", style="filled", fillcolor="#bfdbfe"];
  "metrics_summit_evidence_templates_keel_dscl" [label="metrics.json", shape="component", style="filled", fillcolor="#fecaca"];
  "stamp_summit_evidence_templates_keel_dscl" [label="stamp.json", shape="tab", style="filled", fillcolor="#fef08a"];
  "group_summit_evidence_templates_keel_stab" [label="Evidence Bundle\nkeel-stab\n(summit/evidence/templates/keel-stab)", shape="folder", style="filled", fillcolor="#e2e8f0"];
  "report_summit_evidence_templates_keel_stab" [label="report.json", shape="note", style="filled", fillcolor="#bfdbfe"];
  "metrics_summit_evidence_templates_keel_stab" [label="metrics.json", shape="component", style="filled", fillcolor="#fecaca"];
  "stamp_summit_evidence_templates_keel_stab" [label="stamp.json", shape="tab", style="filled", fillcolor="#fef08a"];
  "group_artifacts_ai_evals" [label="Evidence Bundle\nai-evals\n(artifacts/ai-evals)", shape="folder", style="filled", fillcolor="#e2e8f0"];
  "report_artifacts_ai_evals" [label="report.json", shape="note", style="filled", fillcolor="#bfdbfe"];
  "metrics_artifacts_ai_evals" [label="metrics.json", shape="component", style="filled", fillcolor="#fecaca"];
  "stamp_artifacts_ai_evals" [label="stamp.json", shape="tab", style="filled", fillcolor="#fef08a"];

  "group_summit_evidence_examples" -> "report_summit_evidence_examples" [style="dashed"];
  "group_summit_evidence_examples" -> "metrics_summit_evidence_examples" [style="dashed"];
  "group_summit_evidence_examples" -> "stamp_summit_evidence_examples" [style="dashed"];
  "group_summit_evidence_fixtures_fail_bundle_evidence" -> "report_summit_evidence_fixtures_fail_bundle_evidence" [style="dashed"];
  "group_summit_evidence_fixtures_pass_bundle_evidence" -> "report_summit_evidence_fixtures_pass_bundle_evidence" [style="dashed"];
  "group_summit_evidence_fixtures_pass_bundle_evidence" -> "metrics_summit_evidence_fixtures_pass_bundle_evidence" [style="dashed"];
  "group_summit_evidence_fixtures_pass_bundle_evidence" -> "stamp_summit_evidence_fixtures_pass_bundle_evidence" [style="dashed"];
  "group_summit_evidence_templates" -> "report_summit_evidence_templates" [style="dashed"];
  "group_summit_evidence_templates" -> "metrics_summit_evidence_templates" [style="dashed"];
  "group_summit_evidence_templates" -> "stamp_summit_evidence_templates" [style="dashed"];
  "group_summit_evidence_templates_keel_arch" -> "report_summit_evidence_templates_keel_arch" [style="dashed"];
  "group_summit_evidence_templates_keel_arch" -> "metrics_summit_evidence_templates_keel_arch" [style="dashed"];
  "group_summit_evidence_templates_keel_arch" -> "stamp_summit_evidence_templates_keel_arch" [style="dashed"];
  "group_summit_evidence_templates_keel_bench" -> "report_summit_evidence_templates_keel_bench" [style="dashed"];
  "group_summit_evidence_templates_keel_bench" -> "metrics_summit_evidence_templates_keel_bench" [style="dashed"];
  "group_summit_evidence_templates_keel_bench" -> "stamp_summit_evidence_templates_keel_bench" [style="dashed"];
  "group_summit_evidence_templates_keel_dscl" -> "report_summit_evidence_templates_keel_dscl" [style="dashed"];
  "group_summit_evidence_templates_keel_dscl" -> "metrics_summit_evidence_templates_keel_dscl" [style="dashed"];
  "group_summit_evidence_templates_keel_dscl" -> "stamp_summit_evidence_templates_keel_dscl" [style="dashed"];
  "group_summit_evidence_templates_keel_stab" -> "report_summit_evidence_templates_keel_stab" [style="dashed"];
  "group_summit_evidence_templates_keel_stab" -> "metrics_summit_evidence_templates_keel_stab" [style="dashed"];
  "group_summit_evidence_templates_keel_stab" -> "stamp_summit_evidence_templates_keel_stab" [style="dashed"];
  "group_artifacts_ai_evals" -> "report_artifacts_ai_evals" [style="dashed"];
  "group_artifacts_ai_evals" -> "metrics_artifacts_ai_evals" [style="dashed"];
  "group_artifacts_ai_evals" -> "stamp_artifacts_ai_evals" [style="dashed"];
}
