{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://summit.local/plugins/claude/manifest.schema.json",
  "title": "Claude Business Plugin Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "plugin_id",
    "version",
    "capabilities",
    "oauth_scopes",
    "network",
    "audit"
  ],
  "properties": {
    "plugin_id": {
      "type": "string",
      "minLength": 3
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true,
      "default": []
    },
    "oauth_scopes": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true,
      "default": []
    },
    "network": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "egress_allowlist"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "egress_allowlist": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        }
      }
    },
    "external_write": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false
        },
        "targets_allowlist": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        }
      },
      "default": {
        "enabled": false,
        "targets_allowlist": []
      }
    },
    "audit": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "log_hooks"
      ],
      "properties": {
        "log_hooks": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        }
      }
    }
  }
}
