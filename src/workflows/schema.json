{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Summit MWS Workflow",
  "type": "object",
  "required": ["version", "workflow_id", "policy", "inputs", "steps", "outputs"],
  "properties": {
    "version": { "type": "number" },
    "workflow_id": { "type": "string" },
    "description": { "type": "string" },
    "policy": {
      "type": "object",
      "required": ["network", "connectors"],
      "properties": {
        "network": { "type": "string", "enum": ["deny", "allow"] },
        "connectors": {
          "type": "object",
          "required": ["allowlist"],
          "properties": {
            "allowlist": { "type": "array", "items": { "type": "string" } }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "inputs": { "type": "object" },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type", "mode"],
        "properties": {
          "id": { "type": "string" },
          "type": { "type": "string" },
          "mode": { "type": "string" },
          "fixture": { "type": "string" },
          "params": { "type": "object" }
        },
        "additionalProperties": true
      }
    },
    "outputs": { "type": "object" }
  },
  "additionalProperties": true
}
