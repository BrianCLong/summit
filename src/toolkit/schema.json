{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://summit.local/schemas/toolkit/tool.schema.json",
  "title": "SummitTool",
  "type": "object",
  "required": ["tool_id", "name", "primary_url", "categories", "capabilities", "risk", "access"],
  "properties": {
    "tool_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9\\-]{2,64}$",
      "description": "Stable, lowercase slug. Example: google-earth-pro"
    },
    "name": { "type": "string" },
    "vendor": { "type": "string" },
    "primary_url": { "type": "string", "format": "uri" },
    "docs_url": { "type": "string", "format": "uri" },
    "source": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "description": "e.g., bellingcat-toolkit" },
        "source_url": { "type": "string", "format": "uri" },
        "source_record_id": { "type": "string", "description": "Optional upstream id/path" },
        "retrieved_at": {
          "type": "string",
          "description": "Non-deterministic timestamps must NOT enter deterministic outputs; keep this only in non-deterministic logs."
        }
      }
    },
    "categories": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1,
      "description": "High-level categorization: geolocation, archiving, reverse-image, video, social, etc."
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "reverse_image_search",
          "video_frame_extraction",
          "metadata_exif",
          "geocoding",
          "satellite_imagery",
          "street_level_imagery",
          "chronolocation_solar",
          "archiving",
          "web_archive_lookup",
          "flight_tracking",
          "ship_tracking",
          "username_enumeration",
          "graph_analysis",
          "document_search",
          "sanctions_watchlist"
        ]
      },
      "minItems": 1
    },
    "access": {
      "type": "object",
      "required": ["auth_required", "cost", "api_available", "network_required"],
      "properties": {
        "auth_required": { "type": "boolean" },
        "cost": { "type": "string", "enum": ["free", "freemium", "paid", "unknown"] },
        "api_available": { "type": "boolean" },
        "network_required": { "type": "boolean", "description": "True for web tools; false for offline binaries." },
        "rate_limits_known": { "type": "boolean" }
      }
    },
    "risk": {
      "type": "object",
      "required": ["tos_sensitivity", "pii_risk", "abuse_risk"],
      "properties": {
        "tos_sensitivity": { "type": "string", "enum": ["low", "medium", "high"] },
        "pii_risk": { "type": "string", "enum": ["low", "medium", "high"] },
        "abuse_risk": { "type": "string", "enum": ["low", "medium", "high"] },
        "notes": { "type": "string" }
      }
    },
    "limitations": { "type": "array", "items": { "type": "string" } },
    "inputs": { "type": "array", "items": { "type": "string" } },
    "outputs": { "type": "array", "items": { "type": "string" } },
    "maint": {
      "type": "object",
      "properties": {
        "last_validated_yyyymmdd": { "type": "string", "pattern": "^\\d{8}$" },
        "healthcheck": {
          "type": "object",
          "properties": {
            "kind": { "type": "string", "enum": ["http_head", "http_get", "none"] },
            "url": { "type": "string", "format": "uri" },
            "expect_status": { "type": "integer" }
          }
        }
      }
    }
  }
}
