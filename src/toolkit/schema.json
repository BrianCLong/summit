{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Summit Tool Registry Record",
  "type": "object",
  "required": ["tool_id", "name", "source", "homepage", "categories", "risk", "availability"],
  "properties": {
    "tool_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_\\-]{2,80}$" },
    "name": { "type": "string", "minLength": 2 },
    "source": { "type": "string", "enum": ["bellingcat"] },
    "homepage": { "type": "string", "format": "uri" },
    "toolkit_page": { "type": "string", "format": "uri" },
    "categories": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "availability": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "type": "string", "enum": ["web", "desktop", "cli", "api", "dataset"] },
        "auth_required": { "type": "boolean", "default": false },
        "cost": { "type": "string", "enum": ["free", "freemium", "paid", "unknown"], "default": "unknown" }
      },
      "additionalProperties": false
    },
    "risk": {
      "type": "object",
      "required": ["data_sensitivity", "tos_risk", "pii_risk"],
      "properties": {
        "data_sensitivity": { "type": "string", "enum": ["low", "medium", "high"] },
        "tos_risk": { "type": "string", "enum": ["low", "medium", "high"] },
        "pii_risk": { "type": "string", "enum": ["low", "medium", "high"] }
      },
      "additionalProperties": false
    },
    "notes": { "type": "string" },
    "limitations": { "type": "array", "items": { "type": "string" } },
    "evidence": {
      "type": "object",
      "required": ["claim_ids"],
      "properties": {
        "claim_ids": { "type": "array", "items": { "type": "string" }, "minItems": 1 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
