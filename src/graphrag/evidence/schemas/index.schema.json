{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Evidence Index Schema",
  "type": "object",
  "properties": {
    "version": { "type": "string", "enum": ["1.0"] },
    "item_slug": { "type": "string", "enum": ["INFOWAR"] },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "evidence_id": { "type": "string" },
          "files": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "required": ["evidence_id", "files"]
      }
    }
  },
  "required": ["version", "item_slug", "entries"]
}
