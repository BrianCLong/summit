{
  "$id": "https://summit.local/schemas/infowar/index.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["version", "item_slug"],
  "properties": {
    "version": { "type": "string" },
    "item_slug": { "type": "string" },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["evidence_id", "files"],
        "properties": {
          "evidence_id": { "type": "string" },
          "files": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  },
  "additionalProperties": true
}
