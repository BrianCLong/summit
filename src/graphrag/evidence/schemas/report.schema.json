{
  "$id": "https://summit.local/schemas/infowar/report.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["evidence_id", "item_slug"],
  "properties": {
    "evidence_id": { "type": "string" },
    "item_slug": { "type": "string", "const": "INFOWAR" },
    "findings": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": true
}
