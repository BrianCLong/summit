{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Evidence Report",
  "type": "object",
  "required": ["evidence_id", "summary", "details"],
  "properties": {
    "evidence_id": {
      "type": "string",
      "pattern": "^EVD-INFOWAR-[A-Z]+-[0-9]{3}$"
    },
    "summary": {
      "type": "string"
    },
    "details": {
      "type": "object"
    }
  },
  "additionalProperties": false
}
