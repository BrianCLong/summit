{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Evidence Report Schema",
  "type": "object",
  "properties": {
    "evidence_id": { "type": "string" },
    "summary": { "type": "string" },
    "findings": {
      "type": "array",
      "items": { "type": "string" }
    },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
  },
  "required": ["evidence_id", "summary", "findings", "confidence"]
}
