{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Evidence Stamp",
  "type": "object",
  "required": ["evidence_id", "timestamp", "hash"],
  "properties": {
    "evidence_id": {
      "type": "string",
      "pattern": "^EVD-INFOWAR-[A-Z]+-[0-9]{3}$"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "hash": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
