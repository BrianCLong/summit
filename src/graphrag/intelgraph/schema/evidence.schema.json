{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IntelGraph Evidence Schema",
  "type": "object",
  "required": [
    "evidence_id",
    "entity_refs",
    "edge_refs",
    "provenance",
    "confidence"
  ],
  "properties": {
    "evidence_id": {
      "type": "string",
      "pattern": "^IG-[A-Z]+-[A-Z]+-[0-9]{4}$"
    },
    "entity_refs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "edge_refs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "provenance": {
      "type": "object",
      "required": ["source_type", "source_ref", "collection_method"],
      "properties": {
        "source_type": { "type": "string" },
        "source_ref": { "type": "string" },
        "collection_method": { "type": "string" }
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  },
  "additionalProperties": false
}
