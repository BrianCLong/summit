{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://summit.ai/schemas/evidence-stamp.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "hash", "generated_at"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "hash": {
      "type": "string",
      "minLength": 8
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
