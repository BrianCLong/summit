{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://summit.ai/schemas/evidence-report.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "evidence_id", "summary"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "evidence_id": {
      "type": "string",
      "pattern": "^EVD-[a-z0-9-]+-[A-Z]+-\\d{3}$"
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
