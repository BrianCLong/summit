{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Summit Evidence Bundle",
  "type": "object",
  "required": ["evid", "inputs", "policy", "steps", "findings", "hashes"],
  "properties": {
    "evid": { "type": "string" },
    "inputs": { "type": "object" },
    "policy": { "type": "object" },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["step_id", "type", "mode", "status", "artifacts"],
        "properties": {
          "step_id": { "type": "string" },
          "type": { "type": "string" },
          "mode": { "type": "string" },
          "status": { "type": "string", "enum": ["ok", "skipped", "blocked", "error"] },
          "artifacts": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": false
      }
    },
    "findings": { "type": "array", "items": { "type": "object" } },
    "hashes": {
      "type": "object",
      "required": ["input_manifest_sha256", "bundle_sha256"],
      "properties": {
        "input_manifest_sha256": { "type": "string" },
        "bundle_sha256": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
