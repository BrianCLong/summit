{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      },
      {
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "enable": true,
        "expr": "ALERTS{alertname=~\"CostAnomalyDetected|BudgetExceeded\", alertstate=\"firing\"}",
        "hide": false,
        "iconColor": "red",
        "name": "Cost Anomaly Annotations",
        "tagKeys": "alertname",
        "titleFormat": "{{ alertname }}",
        "type": "tags"
      }
    ]
  },
  "description": "IntelGraph v5.0.0 Cost Guardrails - Overview Dashboard",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "Current Month Spend",
      "description": "Total accumulated cost for the current calendar month",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 8000 },
              { "color": "red", "value": 9000 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "expr": "sum(intelgraph_cost_usd_total{environment=~\"$environment\"})",
          "legendFormat": "Current Month Spend",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Projected Month-End Total",
      "description": "Linear projection of month-end total based on current daily run rate",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 8000 },
              { "color": "red", "value": 10000 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "expr": "sum(intelgraph_cost_usd_total{environment=~\"$environment\"}) / day_of_month() * 30",
          "legendFormat": "Projected Total",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Budget vs Actual - Development",
      "description": "Budget utilization gauge for the development environment",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 4, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1.5,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.8 },
              { "color": "red", "value": 1.0 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "expr": "intelgraph_budget_utilization_ratio{environment=\"development\"}",
          "legendFormat": "Development",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Budget vs Actual - Staging",
      "description": "Budget utilization gauge for the staging environment",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 4, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1.5,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.8 },
              { "color": "red", "value": 1.0 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "expr": "intelgraph_budget_utilization_ratio{environment=\"staging\"}",
          "legendFormat": "Staging",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Budget vs Actual - Production",
      "description": "Budget utilization gauge for the production environment",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 4, "x": 20, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1.5,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.8 },
              { "color": "red", "value": 1.0 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "expr": "intelgraph_budget_utilization_ratio{environment=\"production\"}",
          "legendFormat": "Production",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "Daily Cost Trend",
      "description": "Time series of daily cost over the past 30 days",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20,
            "pointSize": 5,
            "lineWidth": 2,
            "showPoints": "auto",
            "spanNulls": false,
            "axisCenteredZero": false,
            "axisLabel": "Cost (USD)"
          },
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "sum"] }
      },
      "targets": [
        {
          "expr": "sum by (environment) (intelgraph_daily_cost_usd{environment=~\"$environment\"})",
          "legendFormat": "{{ environment }}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "Cost by Operation Type",
      "description": "Breakdown of cost by operation type for the current period",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "pieType": "donut",
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "values": ["value", "percent"]
        }
      },
      "targets": [
        {
          "expr": "sum by (operation) (intelgraph_cost_usd_total{environment=~\"$environment\"})",
          "legendFormat": "{{ operation }}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "title": "Top Tenants by Cost",
      "description": "Table showing the top tenants ranked by total cost",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "custom": {
            "align": "auto",
            "displayMode": "auto"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "tenant" },
            "properties": [
              { "id": "custom.width", "value": 200 },
              { "id": "displayName", "value": "Tenant" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [
              { "id": "displayName", "value": "Total Cost (USD)" },
              { "id": "unit", "value": "currencyUSD" }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "footer": { "show": true, "reducer": ["sum"], "countRows": false },
        "sortBy": [{ "displayName": "Total Cost (USD)", "desc": true }]
      },
      "transformations": [
        {
          "id": "sortBy",
          "options": {
            "fields": {},
            "sort": [{ "field": "Value", "desc": true }]
          }
        },
        {
          "id": "limit",
          "options": { "limitField": 20 }
        }
      ],
      "targets": [
        {
          "expr": "topk(20, sum by (tenant) (intelgraph_cost_usd_total{environment=~\"$environment\"}))",
          "legendFormat": "{{ tenant }}",
          "refId": "A",
          "format": "table",
          "instant": true
        }
      ]
    },
    {
      "id": 9,
      "title": "Cost Anomaly Timeline",
      "description": "Day-over-day cost change percentage with anomaly threshold annotation",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "pointSize": 5,
            "lineWidth": 2,
            "showPoints": "auto",
            "spanNulls": false,
            "thresholdsStyle": { "mode": "line" }
          },
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.20 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "expr": "(intelgraph_daily_cost_usd{environment=~\"$environment\"} - intelgraph_daily_cost_usd{environment=~\"$environment\"} offset 1d) / intelgraph_daily_cost_usd{environment=~\"$environment\"} offset 1d",
          "legendFormat": "{{ environment }} DoD change",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "5m",
  "schemaVersion": 39,
  "tags": ["cost", "finops", "intelgraph", "v5.0.0"],
  "templating": {
    "list": [
      {
        "current": {
          "selected": false,
          "text": "Prometheus",
          "value": "prometheus"
        },
        "hide": 0,
        "includeAll": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "regex": "",
        "type": "datasource"
      },
      {
        "allValue": ".*",
        "current": {
          "selected": true,
          "text": ["All"],
          "value": ["$__all"]
        },
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "definition": "label_values(intelgraph_budget_utilization_ratio, environment)",
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "name": "environment",
        "options": [],
        "query": {
          "query": "label_values(intelgraph_budget_utilization_ratio, environment)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": {
    "from": "now-30d",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "utc",
  "title": "IntelGraph Cost Overview",
  "uid": "intelgraph-cost-overview",
  "version": 1
}
