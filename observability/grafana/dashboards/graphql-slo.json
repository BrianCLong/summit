{
  "dashboard": {
    "title": "GraphQL API SLO Dashboard",
    "tags": ["slo", "graphql", "observability"],
    "timezone": "browser",
    "panels": [
      {
        "title": "GraphQL p95 Latency",
        "type": "graph",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(graphql_operation_duration_seconds_bucket[5m]))",
            "legendFormat": "p95 latency"
          },
          {
            "expr": "0.5",
            "legendFormat": "SLO target (500ms)"
          }
        ],
        "yaxes": [
          { "format": "s", "label": "Latency" }
        ],
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 }
      },
      {
        "title": "GraphQL Error Rate",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(graphql_errors_total[5m])",
            "legendFormat": "Error rate"
          },
          {
            "expr": "0.01",
            "legendFormat": "SLO target (1%)"
          }
        ],
        "yaxes": [
          { "format": "percentunit", "label": "Error Rate" }
        ],
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 }
      },
      {
        "title": "SLO Compliance",
        "type": "stat",
        "targets": [
          {
            "expr": "slo_compliance_ratio{metric_type=\"latency_p95\"}",
            "legendFormat": "Latency SLO"
          },
          {
            "expr": "slo_compliance_ratio{metric_type=\"error_rate\"}",
            "legendFormat": "Error Rate SLO"
          }
        ],
        "gridPos": { "h": 4, "w": 24, "x": 0, "y": 8 }
      }
    ]
  }
}