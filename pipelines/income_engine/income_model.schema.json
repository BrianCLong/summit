{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "IncomeEngineModelSpec",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "model_type",
    "setup_cost",
    "monthly_traffic",
    "conversion_rate",
    "price",
    "churn_rate",
    "monthly_operating_cost",
    "evidence_links"
  ],
  "properties": {
    "model_type": {
      "type": "string",
      "enum": ["digital_product", "subscription_content", "service_hybrid"]
    },
    "setup_cost": {"type": "number", "minimum": 0},
    "monthly_traffic": {"type": "number", "minimum": 0},
    "conversion_rate": {"type": "number", "minimum": 0, "maximum": 1},
    "price": {"type": "number", "exclusiveMinimum": 0},
    "churn_rate": {"type": "number", "minimum": 0, "maximum": 1},
    "monthly_operating_cost": {"type": "number", "minimum": 0},
    "automation_share": {"type": "number", "minimum": 0, "maximum": 1, "default": 0.5},
    "manual_hours_per_month": {"type": "number", "minimum": 0, "default": 0},
    "evidence_links": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 3}
    }
  }
}
