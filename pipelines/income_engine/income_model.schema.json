{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://summit.local/schemas/income_model.schema.json",
  "title": "Income Engine Model Spec",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "model_type",
    "setup_cost",
    "monthly_traffic",
    "conversion_rate",
    "price",
    "churn_rate"
  ],
  "properties": {
    "model_type": {
      "type": "string",
      "enum": ["digital_product", "subscription", "automation_service"]
    },
    "setup_cost": {"type": "number", "minimum": 0},
    "monthly_operating_cost": {"type": "number", "minimum": 0, "default": 0},
    "monthly_traffic": {"type": "number", "minimum": 0},
    "conversion_rate": {"type": "number", "minimum": 0, "maximum": 1},
    "price": {"type": "number", "exclusiveMinimum": 0},
    "churn_rate": {"type": "number", "minimum": 0, "maximum": 1},
    "projection_months": {"type": "integer", "minimum": 1, "maximum": 60, "default": 12},
    "evidence_date": {
      "type": "string",
      "pattern": "^[0-9]{8}$",
      "default": "19700101"
    },
    "evidence_links": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "minItems": 1
    },
    "claims": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "default": []
    }
  }
}
