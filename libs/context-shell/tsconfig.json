{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "node",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "module": "ESNext",
    "target": "ES2022",
    "moduleResolution": "Bundler",
    "types": ["node"],
    "lib": ["ES2022"]
  },
  "include": ["node/**/*"],
  "exclude": ["dist"]
}
