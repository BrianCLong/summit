{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "adk/spec/metrics.schema.json",
  "title": "Summit Bench Metrics Artifact",
  "description": "Deterministic performance and evaluation metrics for an agent run.",
  "type": "object",
  "required": ["metrics_version", "scores"],
  "properties": {
    "metrics_version": { "type": "string" },
    "scores": {
      "type": "object",
      "additionalProperties": { "type": "number" }
    },
    "counts": {
      "type": "object",
      "additionalProperties": { "type": "integer" }
    }
  }
}
