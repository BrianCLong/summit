{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "adk/spec/plan.schema.json",
  "title": "Summit Bench Plan Artifact",
  "description": "Execution plan generated by an agent prior to or during a run.",
  "type": "object",
  "required": ["plan_version", "goal", "tasks"],
  "properties": {
    "plan_version": { "type": "string" },
    "goal": { "type": "string" },
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "description", "status"],
        "properties": {
          "id": { "type": "string" },
          "description": { "type": "string" },
          "status": { "type": "string", "enum": ["pending", "in_progress", "completed", "failed"] },
          "dependencies": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
