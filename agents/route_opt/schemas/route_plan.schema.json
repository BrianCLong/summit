{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://summit.local/schemas/route_plan.schema.json",
  "title": "Route Optimization Report",
  "type": "object",
  "required": [
    "evidence_id",
    "schema_version",
    "input_hash",
    "constraints",
    "stops",
    "distance_matrix",
    "solution"
  ],
  "properties": {
    "evidence_id": {
      "type": "string",
      "pattern": "^EVID-[A-Z0-9-]+$"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "input_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "constraints": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "max_distance_km": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "stops": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "x", "y"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "x": { "type": "number" },
          "y": { "type": "number" }
        }
      }
    },
    "distance_matrix": {
      "type": "array",
      "items": {
        "type": "array",
        "items": { "type": "number", "minimum": 0 }
      }
    },
    "solution": {
      "type": "object",
      "required": ["route", "total_distance_km"],
      "additionalProperties": false,
      "properties": {
        "route": {
          "type": "array",
          "items": { "type": "string" }
        },
        "total_distance_km": {
          "type": "number",
          "minimum": 0
        }
      }
    }
  },
  "additionalProperties": false
}
