#!/bin/bash

##
# S-AOS Pre-Commit Validation Hook
#
# This git hook validates code quality and S-AOS requirements before commit.
# It runs before the commit is created and can block commits that don't comply.
#
# Install: cp scripts/hooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit
# Bypass: git commit --no-verify (not recommended)
##

set -e

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Validation counters
ERRORS=0
WARNINGS=0

echo -e "${BLUE}━━━ S-AOS Pre-Commit Validation ━━━${NC}\n"

# ============================================================================
# Check 1: No direct commits to main/master
# ============================================================================

BRANCH=$(git rev-parse --abbrev-ref HEAD)

if [[ "$BRANCH" == "main" || "$BRANCH" == "master" ]]; then
  echo -e "${RED}✗ Direct commits to $BRANCH not allowed${NC}"
  echo "  Create a branch: git checkout -b feature/your-feature"
  echo "  Or use PR workflow"
  echo ""
  ((ERRORS++))
else
  echo -e "${GREEN}✓ Branch: $BRANCH${NC}"
fi

# ============================================================================
# Check 2: No large files (> 10MB)
# ============================================================================

# Get list of files to be committed
FILES=$(git diff --cached --name-only --diff-filter=ACM)

for FILE in $FILES; do
  if [ -f "$FILE" ]; then
    SIZE=$(wc -c < "$FILE")
    if [ $SIZE -gt 10485760 ]; then  # 10MB
      echo -e "${RED}✗ Large file detected: $FILE ($(numfmt --to=iec-i --suffix=B $SIZE))${NC}"
      echo "  Files > 10MB should use Git LFS"
      echo ""
      ((ERRORS++))
    fi
  fi
done

if [ $ERRORS -eq 0 ]; then
  echo -e "${GREEN}✓ No large files${NC}"
fi

# ============================================================================
# Check 3: No secrets in committed files
# ============================================================================

SECRET_PATTERNS=(
  "AKIA[0-9A-Z]{16}"  # AWS Access Key
  "-----BEGIN (RSA |)PRIVATE KEY-----"  # Private keys
  "xoxb-[0-9]+-[0-9]+-[a-zA-Z0-9]+"  # Slack bot token
  "xoxp-[0-9]+-[0-9]+-[a-zA-Z0-9]+"  # Slack user token
  "ghp_[a-zA-Z0-9]{36}"  # GitHub personal access token
  "sk-[a-zA-Z0-9]{48}"  # OpenAI API key
  "password\s*=\s*['\"][^'\"]{8,}"  # Hardcoded passwords
)

for FILE in $FILES; do
  if [ -f "$FILE" ]; then
    for PATTERN in "${SECRET_PATTERNS[@]}"; do
      if grep -qE "$PATTERN" "$FILE"; then
        echo -e "${RED}✗ Potential secret detected in $FILE${NC}"
        echo "  Pattern: $PATTERN"
        echo "  Remove secrets and use environment variables"
        echo ""
        ((ERRORS++))
        break
      fi
    done
  fi
done

if [ $ERRORS -eq 0 ]; then
  echo -e "${GREEN}✓ No secrets detected${NC}"
fi

# ============================================================================
# Check 4: No console.log in production code (warning only)
# ============================================================================

for FILE in $FILES; do
  if [[ "$FILE" =~ \.(js|mjs|ts|tsx)$ ]] && [[ ! "$FILE" =~ __tests__|\.test\.|\.spec\. ]]; then
    if [ -f "$FILE" ]; then
      if grep -qE "console\.(log|debug|info)" "$FILE"; then
        echo -e "${YELLOW}⚠ console.log found in $FILE${NC}"
        echo "  Consider using a proper logging library"
        echo ""
        ((WARNINGS++))
      fi
    fi
  fi
done

# ============================================================================
# Check 5: No .env files committed
# ============================================================================

for FILE in $FILES; do
  if [[ "$FILE" =~ \.env$ ]] && [[ ! "$FILE" =~ \.env\.example$ ]]; then
    echo -e "${RED}✗ .env file should not be committed: $FILE${NC}"
    echo "  Add to .gitignore"
    echo ""
    ((ERRORS++))
  fi
done

if [ $ERRORS -eq 0 ]; then
  echo -e "${GREEN}✓ No .env files${NC}"
fi

# ============================================================================
# Check 6: TypeScript/JavaScript files have valid syntax (if available)
# ============================================================================

if command -v node >/dev/null 2>&1; then
  for FILE in $FILES; do
    if [[ "$FILE" =~ \.(js|mjs)$ ]]; then
      if [ -f "$FILE" ]; then
        if ! node --check "$FILE" 2>/dev/null; then
          echo -e "${RED}✗ Syntax error in $FILE${NC}"
          echo ""
          ((ERRORS++))
        fi
      fi
    fi
  done

  if [ $ERRORS -eq 0 ]; then
    echo -e "${GREEN}✓ JavaScript syntax valid${NC}"
  fi
fi

# ============================================================================
# Check 7: Evidence artifacts have proper structure (for relevant files)
# ============================================================================

for FILE in $FILES; do
  if [[ "$FILE" =~ artifacts/.*/report\.json$ ]]; then
    if [ -f "$FILE" ]; then
      # Check if valid JSON
      if ! jq empty "$FILE" 2>/dev/null; then
        echo -e "${RED}✗ Invalid JSON in evidence artifact: $FILE${NC}"
        echo ""
        ((ERRORS++))
      else
        # Check for required fields
        if ! jq -e '.reportId and .timestamp and .version' "$FILE" >/dev/null 2>&1; then
          echo -e "${YELLOW}⚠ Evidence artifact missing required fields: $FILE${NC}"
          echo "  Required: reportId, timestamp, version"
          echo ""
          ((WARNINGS++))
        fi
      fi
    fi
  fi
done

# ============================================================================
# Check 8: Audit trail files are properly signed (if modified)
# ============================================================================

for FILE in $FILES; do
  if [[ "$FILE" =~ artifacts/repoos/entropy-actions/audit\.json$ ]]; then
    echo -e "${YELLOW}⚠ Audit trail file modified: $FILE${NC}"
    echo "  Audit trails should only be modified by the audit logger"
    echo "  Manual edits will fail signature verification"
    echo ""
    ((WARNINGS++))
  fi
done

# ============================================================================
# Check 9: Package.json changes include lock file update (if applicable)
# ============================================================================

if echo "$FILES" | grep -q "package.json"; then
  if ! echo "$FILES" | grep -q "pnpm-lock.yaml"; then
    echo -e "${YELLOW}⚠ package.json changed but pnpm-lock.yaml not updated${NC}"
    echo "  Run: pnpm install"
    echo ""
    ((WARNINGS++))
  fi
fi

# ============================================================================
# Check 10: Diff size check (warn if > 500 lines changed)
# ============================================================================

DIFF_LINES=$(git diff --cached --numstat | awk '{sum+=$1+$2} END {print sum}')

if [ -n "$DIFF_LINES" ] && [ "$DIFF_LINES" -gt 500 ]; then
  echo -e "${YELLOW}⚠ Large diff: $DIFF_LINES lines changed${NC}"
  echo "  Consider splitting into smaller, atomic commits"
  echo "  S-AOS principle: Surgical changes, one purpose per commit"
  echo ""
  ((WARNINGS++))
fi

# ============================================================================
# Summary
# ============================================================================

echo ""
echo -e "${BLUE}━━━ Pre-Commit Summary ━━━${NC}"
echo ""

if [ $ERRORS -eq 0 ] && [ $WARNINGS -eq 0 ]; then
  echo -e "${GREEN}✅ All pre-commit checks PASSED${NC}"
  echo ""
  exit 0
elif [ $ERRORS -eq 0 ]; then
  echo -e "${YELLOW}⚠️  Pre-commit checks passed with $WARNINGS warning(s)${NC}"
  echo ""
  echo -e "${YELLOW}Consider addressing warnings for better code quality${NC}"
  echo ""
  exit 0
else
  echo -e "${RED}❌ Pre-commit checks FAILED with $ERRORS error(s) and $WARNINGS warning(s)${NC}"
  echo ""
  echo -e "${RED}Please fix errors before committing${NC}"
  echo ""
  echo "Resources:"
  echo "  • S-AOS Examples: docs/governance/S-AOS_EXAMPLES_GOOD_VS_BAD.md"
  echo "  • Bypass (not recommended): git commit --no-verify"
  echo ""
  exit 1
fi
