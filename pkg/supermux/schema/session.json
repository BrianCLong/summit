{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SupermuxSession",
  "type": "object",
  "properties": {
    "session_id": { "type": "string", "pattern": "^SMX-SES-[a-f0-9]+$" },
    "run_id": { "type": "string", "pattern": "^SMX-RUN-[a-f0-9]+$" },
    "name": { "type": "string" }
  },
  "required": ["session_id", "run_id", "name"]
}
