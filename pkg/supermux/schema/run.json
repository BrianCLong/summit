{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SupermuxRun",
  "type": "object",
  "properties": {
    "run_id": { "type": "string", "pattern": "^SMX-RUN-[a-f0-9]+$" },
    "profile": { "type": "string" },
    "agents_count": { "type": "integer" }
  },
  "required": ["run_id", "profile", "agents_count"]
}
