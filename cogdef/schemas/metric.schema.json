{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["metric_id","name","pillar","score","confidence","coverage","evidence_refs"],
  "properties": {
    "metric_id": {"type":"string","pattern":"^COGDEF-[A-Z_]+-\\d{3}$"},
    "name": {"type":"string"},
    "pillar": {"type":"string","enum":["RESILIENCE","INFOSPACE","DECISION","TECHNICAL"]},
    "score": {"type":"number","minimum":0,"maximum":100},
    "confidence": {"type":"number","minimum":0,"maximum":1},
    "coverage": {"type":"number","minimum":0,"maximum":1},
    "notes": {"type":"string"},
    "evidence_refs": {"type":"array","items":{"type":"string","pattern":"^EVD-COGDEF-[A-Z]+-\\d{3}$"}}
  },
  "additionalProperties": false
}
