{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Lineage Schema",
  "description": "OpenLineage-compatible event structure for Summit lineage events",
  "type": "object",
  "required": ["eventType", "eventTime", "run", "job", "producer"],
  "properties": {
    "eventType": { "type": "string", "enum": ["START", "RUNNING", "COMPLETE", "ABORT", "FAIL", "OTHER"] },
    "eventTime": { "type": "string", "format": "date-time" },
    "run": {
      "type": "object",
      "required": ["runId"],
      "properties": {
        "runId": { "type": "string", "format": "uuid" },
        "facets": { "type": "object" }
      }
    },
    "job": {
      "type": "object",
      "required": ["namespace", "name"],
      "properties": {
        "namespace": { "type": "string" },
        "name": { "type": "string" },
        "facets": { "type": "object" }
      }
    },
    "producer": { "type": "string", "format": "uri" },
    "inputs": { "type": "array", "items": { "type": "object" } },
    "outputs": { "type": "array", "items": { "type": "object" } }
  }
}
