{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Summit Assurance Evidence Pack Index",
  "type": "object",
  "required": ["version", "items"],
  "properties": {
    "version": { "type": "string" },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["evidence_id", "kind", "path"],
        "properties": {
          "evidence_id": { "type": "string", "pattern": "^EVIDENCE:omb-m26-05:[a-z]+:[a-f0-9]+:[0-9]+$" },
          "kind": { "enum": ["sbom", "provenance", "vuln", "index"] },
          "path": { "type": "string" }
        }
      }
    }
  }
}
