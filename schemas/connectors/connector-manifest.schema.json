{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://summit/schemas/connectors/connector-manifest.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "name",
    "version",
    "kind",
    "owner",
    "license_class",
    "collection_mode",
    "deterministic",
    "input_schema",
    "output_schema",
    "rate_limit",
    "policy_refs",
    "entity_mappings",
    "evidence"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9_.-]+$" },
    "name": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "kind": { "const": "osint-connector" },
    "owner": { "type": "string", "minLength": 1 },
    "license_class": { "enum": ["public", "commercial", "restricted"] },
    "collection_mode": { "enum": ["api", "file", "scrape", "manual"] },
    "deterministic": { "type": "boolean" },
    "input_schema": { "type": "string", "minLength": 1 },
    "output_schema": { "type": "string", "const": "connector-output.v1" },
    "rate_limit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rps", "burst"],
      "properties": {
        "rps": { "type": "number", "minimum": 0 },
        "burst": { "type": "number", "minimum": 0 }
      }
    },
    "policy_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "entity_mappings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["from", "to"],
        "properties": {
          "from": { "type": "string", "minLength": 1 },
          "to": { "type": "string", "minLength": 1 }
        }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "capture_raw",
        "capture_transform_hash",
        "capture_source_metadata"
      ],
      "properties": {
        "capture_raw": { "type": "boolean" },
        "capture_transform_hash": { "type": "boolean" },
        "capture_source_metadata": { "type": "boolean" }
      }
    }
  }
}
