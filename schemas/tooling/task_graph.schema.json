{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "tooling_task_graph",
  "type": "object",
  "required": ["nodes"],
  "properties": {
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["node_id", "task", "depends_on"],
        "properties": {
          "node_id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_-]*$"
          },
          "task": {
            "type": "string",
            "minLength": 1
          },
          "depends_on": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[a-z][a-z0-9_-]*$"
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
