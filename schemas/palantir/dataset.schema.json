{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Palantir Foundry Dataset",
  "type": "object",
  "required": ["rid", "alias", "schema"],
  "properties": {
    "rid": { "type": "string", "pattern": "^ri.foundry.main.dataset.*" },
    "alias": { "type": "string" },
    "schema": {
      "type": "object",
      "required": ["fields"],
      "properties": {
        "fields": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "type"],
            "properties": {
              "name": { "type": "string" },
              "type": { "type": "string" }
            }
          }
        }
      }
    },
    "provenance": {
      "type": "object",
      "required": ["input_rids"],
      "properties": {
        "input_rids": { "type": "array", "items": { "type": "string" } },
        "transformation_type": { "type": "string" }
      }
    }
  }
}
