{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://summit.dev/schemas/insight-engine/insight.schema.json",
  "title": "Summit Insight",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "insight_id",
    "type",
    "entity_ids",
    "confidence",
    "risk_score",
    "explanation",
    "supporting_evidence",
    "generated_at",
    "algorithm"
  ],
  "properties": {
    "insight_id": { "type": "string", "minLength": 1 },
    "type": {
      "type": "string",
      "enum": ["hub_detection", "anomaly", "proximity", "pattern"]
    },
    "entity_ids": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "risk_score": { "type": "number", "minimum": 0, "maximum": 1 },
    "explanation": { "type": "string", "minLength": 1 },
    "supporting_evidence": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "generated_at": { "type": "string", "format": "date-time" },
    "algorithm": {
      "type": "string",
      "enum": [
        "centrality_v1",
        "transaction_loop_v1",
        "sanctions_proximity_v1",
        "behavioral_anomaly_v1"
      ]
    }
  }
}
