{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.summit.dev/run-manifest/v1.schema.json",
  "title": "Summit Run Manifest",
  "description": "Describes the inputs, outputs, and metadata for a Summit execution run.",
  "type": "object",
  "properties": {
    "schemaVersion": {
      "type": "string",
      "enum": ["v1"]
    },
    "runId": {
      "type": "string",
      "description": "Canonical OpenLineage runId (UUIDv7)."
    },
    "runUri": {
      "type": "string",
      "description": "Stable URI for the run."
    },
    "nominalTime": {
      "type": "string",
      "format": "date-time"
    },
    "inputs": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "namespace": { "type": "string" },
          "name": { "type": "string" },
          "digest": { "type": "string" }
        },
        "required": ["namespace", "name"]
      }
    },
    "outputs": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "namespace": { "type": "string" },
          "name": { "type": "string" },
          "digest": { "type": "string" }
        },
        "required": ["namespace", "name"]
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "required": ["schemaVersion", "runId", "runUri"]
}
