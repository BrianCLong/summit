{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://summit.dev/schemas/receipt.v1.json",
  "title": "Switchboard Privileged Action Receipt v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "approval_id",
    "tenant_id",
    "actor",
    "decision",
    "policy_version",
    "policy_decision_hash",
    "pre_state_hash",
    "post_state_hash",
    "risk_tier",
    "timestamp",
    "cost_estimate",
    "input_hash",
    "signature",
    "key_id"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "switchboard.receipt.v1"
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "approval_id": {
      "type": "string",
      "minLength": 1
    },
    "tenant_id": {
      "type": "string",
      "minLength": 1
    },
    "actor": {
      "type": "object",
      "required": ["id"],
      "additionalProperties": true,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "roles": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "attributes": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "decision": {
      "type": "string",
      "enum": ["created", "approve", "reject", "cancelled"]
    },
    "policy_version": {
      "type": "string",
      "minLength": 1
    },
    "policy_decision_hash": {
      "type": "string",
      "pattern": "^[a-fA-F0-9]{64}$"
    },
    "pre_state_hash": {
      "type": "string",
      "pattern": "^[a-fA-F0-9]{64}$"
    },
    "post_state_hash": {
      "type": "string",
      "pattern": "^[a-fA-F0-9]{64}$"
    },
    "risk_tier": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "cost_estimate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["currency", "amount", "confidence"],
      "properties": {
        "currency": {
          "type": "string",
          "default": "USD"
        },
        "amount": {
          "type": "number"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "input_hash": {
      "type": "string",
      "pattern": "^[a-fA-F0-9]{64}$"
    },
    "signature": {
      "type": "string",
      "minLength": 1
    },
    "key_id": {
      "type": "string",
      "minLength": 1
    }
  }
}
