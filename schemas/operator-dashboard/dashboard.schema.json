{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://summit.dev/schemas/operator-dashboard/dashboard.schema.json",
  "title": "Summit Operator Dashboard",
  "type": "object",
  "additionalProperties": false,
  "required": ["system_status", "agents", "insights", "cost_metrics"],
  "properties": {
    "system_status": {
      "type": "object",
      "additionalProperties": false,
      "required": ["agents_active", "runs_in_progress", "policy_violations", "avg_risk_score"],
      "properties": {
        "agents_active": { "type": "integer", "minimum": 0 },
        "runs_in_progress": { "type": "integer", "minimum": 0 },
        "policy_violations": { "type": "integer", "minimum": 0 },
        "avg_risk_score": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "agents": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["agent_id", "status", "tasks", "risk_score"],
        "properties": {
          "agent_id": { "type": "string", "minLength": 1 },
          "status": { "type": "string", "enum": ["active", "degraded", "paused", "offline"] },
          "tasks": { "type": "integer", "minimum": 0 },
          "risk_score": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    },
    "insights": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["insight_id", "confidence", "risk_score"],
        "properties": {
          "insight_id": { "type": "string", "minLength": 1 },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "risk_score": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    },
    "cost_metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": ["compute_cost_usd", "model_usage"],
      "properties": {
        "compute_cost_usd": { "type": "number", "minimum": 0 },
        "model_usage": {
          "type": "object",
          "additionalProperties": { "type": "number", "minimum": 0 }
        }
      }
    }
  }
}
