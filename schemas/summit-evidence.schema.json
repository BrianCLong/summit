{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Summit Evidence Schema",
  "description": "Canonical ingestion schema for all Summit evidence data sources",
  "type": "object",
  "required": ["evidence_id", "timestamp", "producer", "summary", "artifacts"],
  "properties": {
    "evidence_id": {
      "type": "string",
      "pattern": "^EVD-[A-Z0-9-]+-[0-9]+$"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "producer": {
      "type": "object",
      "required": ["name", "version"],
      "properties": {
        "name": { "type": "string" },
        "version": { "type": "string" },
        "component": { "type": "string" }
      }
    },
    "summary": {
      "type": "object"
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "sha256"],
        "properties": {
          "name": { "type": "string" },
          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
          "uri": { "type": "string", "format": "uri" }
        }
      }
    },
    "lineage": {
      "type": "object",
      "properties": {
        "parent_id": { "type": "string" },
        "transform_hash": { "type": "string" },
        "inputs": { "type": "array", "items": { "type": "string" } }
      }
    },
    "metrics": {
      "type": "object"
    }
  }
}
