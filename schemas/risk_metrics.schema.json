{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://summit.intelgraph.io/schemas/risk_metrics.schema.json",
    "type": "object",
    "title": "Summit Risk Metrics",
    "description": "Quantified, machine-derived, and immutable risk metrics for insurance and board-level reporting.",
    "required": [
        "timestamp",
        "metrics",
        "signature",
        "schema_version"
    ],
    "properties": {
        "schema_version": {
            "type": "string",
            "const": "1.0.0"
        },
        "timestamp": {
            "type": "string",
            "format": "date-time",
            "description": "ISO 8601 timestamp of metric generation (CI enforced)"
        },
        "metrics": {
            "type": "object",
            "required": [
                "integrity_exposure",
                "availability_exposure",
                "auditability_exposure"
            ],
            "properties": {
                "integrity_exposure": {
                    "type": "object",
                    "required": [
                        "score",
                        "violations",
                        "max_exposure_usd"
                    ],
                    "properties": {
                        "score": {
                            "type": "number",
                            "minimum": 0,
                            "maximum": 100,
                            "description": "0 = Total Compromise, 100 = Fully Verified"
                        },
                        "violations": {
                            "type": "integer",
                            "minimum": 0,
                            "description": "Count of active integrity violations (e.g., untrusted commits, failed signatures)"
                        },
                        "max_exposure_usd": {
                            "type": "number",
                            "minimum": 0,
                            "description": "Financial liability cap for current exposure"
                        }
                    }
                },
                "availability_exposure": {
                    "type": "object",
                    "required": [
                        "uptime_sla_compliance",
                        "active_incidents"
                    ],
                    "properties": {
                        "uptime_sla_compliance": {
                            "type": "number",
                            "minimum": 0,
                            "maximum": 100
                        },
                        "active_incidents": {
                            "type": "integer",
                            "minimum": 0
                        }
                    }
                },
                "auditability_exposure": {
                    "type": "object",
                    "required": [
                        "evidence_completeness",
                        "missing_artifacts"
                    ],
                    "properties": {
                        "evidence_completeness": {
                            "type": "number",
                            "minimum": 0,
                            "maximum": 100
                        },
                        "missing_artifacts": {
                            "type": "integer",
                            "minimum": 0
                        }
                    }
                }
            }
        },
        "context": {
            "type": "object",
            "properties": {
                "commit_sha": {
                    "type": "string"
                },
                "trust_state": {
                    "type": "string",
                    "enum": [
                        "GREEN",
                        "AMBER",
                        "RED"
                    ]
                },
                "run_id": {
                    "type": "string"
                }
            }
        },
        "signature": {
            "type": "object",
            "description": "Detached signature of the canonical JSON form of this document (excluding signature)",
            "properties": {
                "value": {
                    "type": "string"
                },
                "key_id": {
                    "type": "string"
                }
            }
        }
    }
}