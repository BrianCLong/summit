{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DocGraph",
  "type": "object",
  "properties": {
    "segments": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {"type": "string"},
          "parent_id": {"type": ["string", "null"]},
          "type": {"type": "string"},
          "start": {"type": "integer"},
          "end": {"type": "integer"},
          "text": {"type": "string"}
        },
        "required": ["id", "type", "start", "end"]
      }
    },
    "entities": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {"type": "string"},
          "type": {"type": "string"},
          "text": {"type": "string"},
          "start": {"type": "integer"},
          "end": {"type": "integer"},
          "segment_id": {"type": "string"}
        },
        "required": ["id", "type", "text", "start", "end", "segment_id"]
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "source": {"type": "string"},
          "target": {"type": "string"},
          "type": {"type": "string"}
        },
        "required": ["source", "target", "type"]
      }
    }
  },
  "required": ["segments", "entities", "edges"]
}
