{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://summit.dev/schemas/evidence-bundle/evidence-bundle.schema.json",
  "title": "Summit Evidence Bundle",
  "type": "object",
  "additionalProperties": false,
  "required": ["run", "provenance", "evidence", "insights", "policy_checks"],
  "properties": {
    "run": {
      "type": "object",
      "required": ["run_id", "started_at", "completed_at", "agents_used", "data_sources"],
      "properties": {
        "run_id": { "type": "string", "minLength": 1 },
        "started_at": { "type": "string", "format": "date-time" },
        "completed_at": { "type": "string", "format": "date-time" },
        "agents_used": { "type": "array", "items": { "type": "string" } },
        "data_sources": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "provenance": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["entity_id", "source", "ingested_at", "confidence"],
        "properties": {
          "entity_id": { "type": "string" },
          "source": { "type": "string" },
          "ingested_at": { "type": "string", "format": "date-time" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
        },
        "additionalProperties": false
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["evidence_id", "type", "source", "hash", "timestamp"],
        "properties": {
          "evidence_id": { "type": "string" },
          "type": { "type": "string" },
          "source": { "type": "string" },
          "hash": { "type": "string", "pattern": "^sha256:[a-fA-F0-9]{64}$" },
          "timestamp": { "type": "string", "format": "date-time" }
        },
        "additionalProperties": false
      }
    },
    "insights": {
      "type": "array",
      "items": { "$ref": "../insight-engine/insight.schema.json" }
    },
    "policy_checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["policy", "status", "action", "timestamp"],
        "properties": {
          "policy": { "type": "string" },
          "status": { "type": "string", "enum": ["passed", "triggered", "failed"] },
          "action": { "type": "string" },
          "timestamp": { "type": "string", "format": "date-time" }
        },
        "additionalProperties": false
      }
    }
  }
}
