{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://summit.dev/schemas/memory/memory-proposal.schema.json",
  "title": "Summit Memory Proposal",
  "type": "object",
  "additionalProperties": false,
  "required": ["proposal_id", "tier", "target_path", "change_type", "diff", "rationale", "risk_flags", "provenance"],
  "properties": {
    "proposal_id": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9._:-]{8,}$"
    },
    "tier": {
      "type": "string",
      "enum": ["agent", "user", "case", "org"]
    },
    "target_path": {
      "type": "string",
      "pattern": "^/summit_memory/(org|users|cases|agents)/.+$"
    },
    "change_type": {
      "type": "string",
      "enum": ["create", "update", "delete", "compact"]
    },
    "diff": {
      "type": "string",
      "minLength": 1
    },
    "rationale": {
      "type": "string",
      "minLength": 10
    },
    "risk_flags": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "prompt_injection_suspected",
          "instruction_persistence",
          "privilege_escalation",
          "pii_exposure",
          "source_unverified"
        ]
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["actor", "timestamp", "source_refs"],
      "properties": {
        "actor": { "type": "string", "minLength": 2 },
        "timestamp": { "type": "string", "format": "date-time" },
        "source_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 3 }
        }
      }
    }
  }
}
