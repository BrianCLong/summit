{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://summit.dev/schemas/memory/skill-frontmatter.schema.json",
  "title": "Summit Skill Frontmatter",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "scope", "when_to_use", "inputs", "outputs", "guardrails"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(\\.[a-z0-9_-]+)+\\.v[0-9]+$"
    },
    "scope": {
      "type": "string",
      "enum": ["agent", "user", "case", "org"]
    },
    "when_to_use": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 3 }
    },
    "inputs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "outputs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "guardrails": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 5 }
    }
  }
}
