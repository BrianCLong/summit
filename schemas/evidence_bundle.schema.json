{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "EvidenceBundle",
  "type": "object",
  "properties": {
    "bundle_id": {
      "type": "string"
    },
    "run_id": {
      "type": "string"
    },
    "evidence_objects": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "bundle_hash": {
      "type": "string"
    }
  },
  "required": ["bundle_id", "run_id", "evidence_objects", "bundle_hash"],
  "additionalProperties": false
}
