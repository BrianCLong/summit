{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://summit.local/schemas/truth-engine/writeset.schema.json",
  "title": "Summit Truth Engine WriteSet",
  "type": "object",
  "additionalProperties": false,
  "required": ["writeset_id", "system_time", "source", "ops", "provenance"],
  "properties": {
    "writeset_id": { "type": "string", "minLength": 3 },
    "system_time": { "type": "string", "format": "date-time" },
    "source": { "type": "string", "minLength": 2 },
    "actor": { "type": "string" },
    "ops": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/Op" }
    },
    "provenance": { "$ref": "#/$defs/Provenance" }
  },
  "$defs": {
    "Provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifacts"],
      "properties": {
        "artifacts": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/ArtifactRef" }
        },
        "ingest_connector": { "type": "string" },
        "trace_id": { "type": "string" }
      }
    },
    "ArtifactRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifact_id", "type", "sha256"],
      "properties": {
        "artifact_id": { "type": "string", "minLength": 3 },
        "type": {
          "type": "string",
          "enum": ["document", "image", "transcript", "sensor", "analyst_note", "post"]
        },
        "sha256": { "type": "string", "pattern": "^[a-fA-F0-9]{64}$" },
        "uri": { "type": "string", "format": "uri-reference" }
      }
    },
    "Bitemporal": {
      "type": "object",
      "additionalProperties": false,
      "required": ["valid_from"],
      "properties": {
        "valid_from": { "type": "string", "format": "date-time" },
        "valid_to": {
          "anyOf": [
            { "type": "string", "format": "date-time" },
            { "type": "null" }
          ]
        }
      }
    },
    "Claim": {
      "type": "object",
      "additionalProperties": false,
      "required": ["claim_id", "subject", "predicate", "object", "confidence", "time", "evidence_ids"],
      "properties": {
        "claim_id": { "type": "string", "minLength": 3 },
        "subject": { "type": "string", "minLength": 1 },
        "predicate": { "type": "string", "minLength": 1 },
        "object": { "type": "string", "minLength": 1 },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "time": { "$ref": "#/$defs/Bitemporal" },
        "evidence_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 3 },
          "minItems": 1
        }
      }
    },
    "UpsertClaim": {
      "type": "object",
      "additionalProperties": false,
      "required": ["op", "graph", "claim"],
      "properties": {
        "op": { "const": "UPSERT_CLAIM" },
        "graph": { "enum": ["NG", "BG", "RG"] },
        "claim": { "$ref": "#/$defs/Claim" }
      }
    },
    "ProposePromotion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["op", "promotion"],
      "properties": {
        "op": { "const": "PROPOSE_PROMOTION" },
        "promotion": {
          "type": "object",
          "additionalProperties": false,
          "required": ["promotion_id", "claim_id", "from_graph", "to_graph"],
          "properties": {
            "promotion_id": { "type": "string", "minLength": 3 },
            "claim_id": { "type": "string", "minLength": 3 },
            "from_graph": { "enum": ["NG", "BG"] },
            "to_graph": { "const": "RG" }
          }
        }
      }
    },
    "Op": {
      "oneOf": [{ "$ref": "#/$defs/UpsertClaim" }, { "$ref": "#/$defs/ProposePromotion" }]
    }
  }
}
