{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Narrative Nodes",
  "type": "object",
  "required": ["version", "nodes"],
  "properties": {
    "version": { "type": "integer" },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "id"],
        "properties": {
          "type": { "type": "string" },
          "id": { "type": "string" },
          "props": { "type": "object" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
