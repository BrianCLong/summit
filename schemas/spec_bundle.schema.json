{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://summit.example.com/schemas/spec_bundle.schema.json",
  "title": "MaestroSpecBundle",
  "description": "Deterministic output bundle generated by maestro_spec_interview_v1.",
  "type": "object",
  "required": [
    "spec_version",
    "mode",
    "title",
    "scope",
    "section_summaries",
    "functional_requirements",
    "non_functional_requirements",
    "data_model",
    "agent_design",
    "interfaces",
    "risk_analysis",
    "acceptance_criteria",
    "open_questions",
    "jules_tasks",
    "codex_tasks",
    "diagnostics",
    "definition_of_done",
    "requirement_index"
  ],
  "additionalProperties": false,
  "properties": {
    "spec_version": { "type": "string" },
    "mode": { "type": "string", "enum": ["standard", "adversarial", "mvs", "compliance"] },
    "title": { "type": "string" },
    "scope": { "type": "string" },
    "section_summaries": {
      "type": "object",
      "required": [
        "functional_requirements",
        "non_functional_requirements",
        "data_model",
        "agent_design",
        "interfaces",
        "risk_analysis",
        "acceptance_criteria"
      ],
      "additionalProperties": false,
      "properties": {
        "functional_requirements": { "type": "string" },
        "non_functional_requirements": { "type": "string" },
        "data_model": { "type": "string" },
        "agent_design": { "type": "string" },
        "interfaces": { "type": "string" },
        "risk_analysis": { "type": "string" },
        "acceptance_criteria": { "type": "string" }
      }
    },
    "functional_requirements": {
      "type": "array",
      "items": { "$ref": "#/$defs/requirement" }
    },
    "non_functional_requirements": {
      "type": "array",
      "items": { "$ref": "#/$defs/requirement" }
    },
    "data_model": {
      "type": "array",
      "items": { "$ref": "#/$defs/requirement" }
    },
    "agent_design": {
      "type": "array",
      "items": { "$ref": "#/$defs/requirement" }
    },
    "interfaces": {
      "type": "array",
      "items": { "$ref": "#/$defs/requirement" }
    },
    "risk_analysis": {
      "type": "array",
      "items": { "$ref": "#/$defs/requirement" }
    },
    "acceptance_criteria": {
      "type": "array",
      "items": { "$ref": "#/$defs/requirement" }
    },
    "open_questions": {
      "type": "array",
      "items": { "$ref": "#/$defs/openQuestion" }
    },
    "jules_tasks": {
      "type": "array",
      "items": { "$ref": "#/$defs/julesTask" }
    },
    "codex_tasks": {
      "type": "array",
      "items": { "$ref": "#/$defs/codexTask" }
    },
    "diagnostics": {
      "type": "object",
      "required": ["contradictions", "ambiguity_hits", "unknown_hits"],
      "additionalProperties": false,
      "properties": {
        "contradictions": {
          "type": "array",
          "items": { "$ref": "#/$defs/contradiction" }
        },
        "ambiguity_hits": {
          "type": "array",
          "items": { "type": "string" }
        },
        "unknown_hits": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "definition_of_done": {
      "type": "object",
      "required": ["scores", "total", "passing_threshold", "passing"],
      "additionalProperties": false,
      "properties": {
        "scores": {
          "type": "object",
          "required": [
            "determinism",
            "machine_verifiability",
            "mergeability",
            "security_posture",
            "measured_advantage"
          ],
          "additionalProperties": false,
          "properties": {
            "determinism": { "type": "integer" },
            "machine_verifiability": { "type": "integer" },
            "mergeability": { "type": "integer" },
            "security_posture": { "type": "integer" },
            "measured_advantage": { "type": "integer" }
          }
        },
        "total": { "type": "integer" },
        "passing_threshold": { "type": "integer" },
        "passing": { "type": "boolean" }
      }
    },
    "requirement_index": {
      "type": "array",
      "items": { "$ref": "#/$defs/requirement" }
    }
  },
  "$defs": {
    "flagSet": {
      "type": "object",
      "required": ["ambiguous", "unknown", "risk"],
      "additionalProperties": false,
      "properties": {
        "ambiguous": { "type": "boolean" },
        "unknown": { "type": "boolean" },
        "risk": { "type": "boolean" }
      }
    },
    "requirement": {
      "type": "object",
      "required": ["id", "text", "section", "flags"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^REQ-[A-Z]+-[0-9]{3}$" },
        "text": { "type": "string" },
        "section": { "type": "string" },
        "flags": { "$ref": "#/$defs/flagSet" }
      }
    },
    "openQuestion": {
      "type": "object",
      "required": ["id", "question", "source", "blocking"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^Q-[0-9]{3}$" },
        "question": { "type": "string" },
        "source": { "type": "string" },
        "blocking": { "type": "boolean" }
      }
    },
    "julesTask": {
      "type": "object",
      "required": ["id", "title", "section", "requirement_ids", "description"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^JULES-TASK-[0-9]{3}$" },
        "title": { "type": "string" },
        "section": { "type": "string" },
        "requirement_ids": { "type": "array", "items": { "type": "string" } },
        "description": { "type": "string" }
      }
    },
    "codexTask": {
      "type": "object",
      "required": ["id", "requirement_id", "title", "module_hint", "description"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^CODEX-TASK-[0-9]{3}$" },
        "requirement_id": { "type": "string", "pattern": "^REQ-[A-Z]+-[0-9]{3}$" },
        "title": { "type": "string" },
        "module_hint": { "type": "string" },
        "description": { "type": "string" }
      }
    },
    "contradiction": {
      "type": "object",
      "required": ["type", "subject", "requirements", "message"],
      "additionalProperties": false,
      "properties": {
        "type": { "type": "string" },
        "subject": { "type": "string" },
        "requirements": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 2,
          "maxItems": 2
        },
        "message": { "type": "string" }
      }
    }
  }
}
