{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://summit.dev/schemas/maestro/spec_bundle.schema.json",
  "title": "Maestro Spec Bundle",
  "type": "object",
  "additionalProperties": false,
  "required": ["metadata", "spec"],
  "properties": {
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifact_id", "mode", "schema_version"],
      "properties": {
        "artifact_id": { "type": "string", "pattern": "^maestro-spec\\.[a-f0-9]{12}$" },
        "mode": { "type": "string", "enum": ["standard", "adversarial", "mvs", "compliance"] },
        "schema_version": { "type": "string", "const": "1.0" }
      }
    },
    "spec": {
      "$ref": "./maestro_spec.schema.json"
    }
  }
}
