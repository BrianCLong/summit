{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://summit.dev/schemas/maestro/maestro_spec.schema.json",
  "title": "Maestro Interview Spec",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "spec_version",
    "scope",
    "functional_requirements",
    "non_functional_requirements",
    "data_model",
    "agent_design",
    "interfaces",
    "risk_analysis",
    "acceptance_criteria",
    "open_questions",
    "jules_tasks",
    "codex_tasks"
  ],
  "properties": {
    "spec_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+$" },
    "scope": { "$ref": "#/$defs/section" },
    "functional_requirements": { "$ref": "#/$defs/requirementSection" },
    "non_functional_requirements": { "$ref": "#/$defs/requirementSection" },
    "data_model": { "$ref": "#/$defs/section" },
    "agent_design": { "$ref": "#/$defs/section" },
    "interfaces": { "$ref": "#/$defs/section" },
    "risk_analysis": { "$ref": "#/$defs/riskSection" },
    "acceptance_criteria": { "$ref": "#/$defs/requirementSection" },
    "open_questions": {
      "type": "array",
      "items": { "$ref": "#/$defs/question" }
    },
    "jules_tasks": {
      "type": "array",
      "items": { "$ref": "#/$defs/taskSeed" }
    },
    "codex_tasks": {
      "type": "array",
      "items": { "$ref": "#/$defs/taskSeed" }
    }
  },
  "$defs": {
    "section": {
      "type": "object",
      "additionalProperties": false,
      "required": ["summary", "requirements"],
      "properties": {
        "summary": { "type": "string", "minLength": 1 },
        "requirements": {
          "type": "array",
          "items": { "$ref": "#/$defs/requirement" }
        }
      }
    },
    "requirementSection": {
      "allOf": [{ "$ref": "#/$defs/section" }]
    },
    "riskSection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["summary", "requirements", "risks"],
      "properties": {
        "summary": { "type": "string", "minLength": 1 },
        "requirements": {
          "type": "array",
          "items": { "$ref": "#/$defs/requirement" }
        },
        "risks": {
          "type": "array",
          "items": { "$ref": "#/$defs/risk" }
        }
      }
    },
    "requirement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "statement"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^REQ-[A-Z_]+-[0-9]{3}$"
        },
        "statement": { "type": "string", "minLength": 1 },
        "priority": {
          "type": "string",
          "enum": ["must", "should", "could"]
        }
      }
    },
    "risk": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "description", "severity"],
      "properties": {
        "id": { "type": "string", "pattern": "^RISK-[0-9]{3}$" },
        "description": { "type": "string", "minLength": 1 },
        "severity": { "type": "string", "enum": ["low", "medium", "high"] }
      }
    },
    "question": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "question", "blocking"],
      "properties": {
        "id": { "type": "string", "pattern": "^Q-[0-9]{3}$" },
        "question": { "type": "string", "minLength": 1 },
        "blocking": { "type": "boolean" }
      }
    },
    "taskSeed": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "inputs"],
      "properties": {
        "id": { "type": "string", "pattern": "^(JULES|CODEX)-TASK-[0-9]{3}$" },
        "title": { "type": "string", "minLength": 1 },
        "inputs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
