{
  "$id": "https://summit.dev/schemas/agent-doc.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Agent Documentation Contract",
  "type": "object",
  "required": [
    "module_name",
    "version",
    "input_schema",
    "output_schema",
    "policy_constraints",
    "side_effects",
    "deterministic",
    "evidence_id_pattern"
  ],
  "properties": {
    "module_name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "input_schema": {
      "type": "object"
    },
    "output_schema": {
      "type": "object"
    },
    "policy_constraints": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "side_effects": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "name",
          "effect_type",
          "scope"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "effect_type": {
            "type": "string",
            "enum": [
              "none",
              "read",
              "write",
              "network",
              "external_call"
            ]
          },
          "scope": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    },
    "deterministic": {
      "type": "boolean"
    },
    "evidence_id_pattern": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": false
}
