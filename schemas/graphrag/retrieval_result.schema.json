{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RetrievalResult",
  "type": "object",
  "required": ["contract_version","request","seeds","expanded","edges","stats","deterministic"],
  "properties": {
    "contract_version": { "type": "string", "enum": ["v1"] },
    "request": {
      "type": "object",
      "required": ["query_hash","policy_hash","graph_ref"],
      "properties": {
        "query_hash": { "type": "string" },
        "policy_hash": { "type": "string" },
        "graph_ref": { "type": "string" }
      }
    },
    "seeds": { "type": "array", "items": { "$ref": "#/$defs/evidenceObject" } },
    "expanded": { "type": "array", "items": { "$ref": "#/$defs/evidenceObject" } },
    "edges": { "type": "array", "items": { "$ref": "#/$defs/edgeRef" } },
    "stats": { "type": "object" },
    "deterministic": { "type": "object" }
  },
  "$defs": {
    "evidenceObject": {
      "type": "object",
      "required": ["evidence_id","kind","excerpt","digest"],
      "properties": {
        "evidence_id": { "type": "string" },
        "kind": { "type": "string" },
        "title": { "type": "string" },
        "excerpt": { "type": "string" },
        "uri": { "type": "string" },
        "score": { "type": "number" },
        "digest": { "type": "object", "required": ["sha256"], "properties": { "sha256": { "type": "string" } } },
        "provenance": { "type": "object" }
      }
    },
    "edgeRef": {
      "type": "object",
      "required": ["from","to","type"],
      "properties": {
        "from": { "type": "string" },
        "to": { "type": "string" },
        "type": { "type": "string" }
      }
    }
  }
}
