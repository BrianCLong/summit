{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.summit.dev/openlineage/facets/summit_provenance_run_facet/v1.schema.json",
  "title": "Summit Provenance Run Facet",
  "type": "object",
  "properties": {
    "_producer": { "type": "string", "format": "uri" },
    "_schemaURL": { "type": "string", "format": "uri" },
    "runManifestDigest": {
      "type": "object",
      "properties": {
        "sha256": { "type": "string" }
      },
      "required": ["sha256"]
    },
    "attestations": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "uri": { "type": "string", "format": "uri" },
          "digest": {
            "type": "object",
            "properties": {
              "sha256": { "type": "string" }
            },
            "required": ["sha256"]
          },
          "predicateType": { "type": "string", "format": "uri" }
        },
        "required": ["uri", "digest", "predicateType"]
      }
    },
    "sboms": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "uri": { "type": "string", "format": "uri" },
          "digest": {
            "type": "object",
            "properties": {
              "sha256": { "type": "string" }
            },
            "required": ["sha256"]
          }
        },
        "required": ["uri", "digest"]
      }
    }
  },
  "required": ["_producer", "_schemaURL", "runManifestDigest", "attestations"]
}
