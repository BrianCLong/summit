{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.summit.dev/openlineage/facets/summit_provenance_run_facet/v1.json",
  "title": "SummitProvenanceFacet",
  "type": "object",
  "properties": {
    "_schemaURL": {
      "type": "string",
      "format": "uri"
    },
    "runManifest": {
      "type": "object",
      "properties": {
        "sha256": { "type": "string" }
      },
      "required": ["sha256"]
    },
    "attestations": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "uri": { "type": "string" },
          "digest": {
            "type": "object",
            "properties": {
              "sha256": { "type": "string" }
            },
            "required": ["sha256"]
          },
          "predicateType": { "type": "string" }
        },
        "required": ["uri", "digest", "predicateType"]
      }
    }
  },
  "required": ["_schemaURL", "runManifest", "attestations"]
}
