{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://summit.com/schemas/world-model/entity.schema.json",
  "title": "World Model Entity",
  "type": "object",
  "properties": {
    "entity_id": {
      "type": "string"
    },
    "type": {
      "type": "string"
    },
    "current_state": {
      "type": "string",
      "enum": ["unknown", "open", "in_progress", "blocked", "degraded", "resolved", "closed"]
    },
    "owner": {
      "type": "string"
    },
    "last_changed_by_event": {
      "type": "string"
    },
    "allowed_actions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "policy_scope": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": ["entity_id", "type", "current_state"]
}
