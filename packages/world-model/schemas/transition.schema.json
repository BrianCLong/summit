{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://summit.com/schemas/world-model/transition.schema.json",
  "title": "World Model State Transition",
  "type": "object",
  "properties": {
    "from_state": {
      "type": "string"
    },
    "to_state": {
      "type": "string"
    },
    "event_type": {
      "type": "string"
    },
    "conditions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": ["from_state", "to_state", "event_type"]
}
