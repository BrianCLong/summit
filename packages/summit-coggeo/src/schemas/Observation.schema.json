{
  "$id": "https://schemas.summit.dev/coggeo/Observation.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Observation",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "ts", "source", "content", "provenance"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "ts": { "type": "string", "format": "date-time" },
    "source": { "type": "string", "minLength": 1 },
    "author": { "type": ["string", "null"] },
    "url": { "type": ["string", "null"], "format": "uri" },
    "lang": { "type": ["string", "null"] },
    "content": { "type": "string", "minLength": 1 },
    "geo": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "properties": {
        "h3": { "type": "string" },
        "country": { "type": ["string", "null"] },
        "region": { "type": ["string", "null"] }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["collector", "hash"],
      "properties": {
        "collector": { "type": "string", "minLength": 1 },
        "hash": { "type": "string", "minLength": 8 },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1, "default": 1 },
        "model": { "type": ["string", "null"] },
        "prompt_id": { "type": ["string", "null"] }
      }
    }
  }
}
