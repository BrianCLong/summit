{
  "name": "@summit/summit-coggeo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "coggeo:toy": "node --enable-source-maps dist/bin/runToyPipeline.js",
    "coggeo:devserver": "node --enable-source-maps dist/bin/devServer.js",
    "coggeo:demo": "npm run build && npm run coggeo:toy && npm run coggeo:devserver",
    "coggeo:smoke": "node --enable-source-maps dist/bin/smokeTest.js",
    "coggeo:bootstrap": "node --enable-source-maps dist/bin/demoBootstrap.js",
    "coggeo:compose": "node --enable-source-maps dist/bin/demoCompose.js"
  },
  "dependencies": {
    "ajv": "8.18.0",
    "ajv-formats": "3.0.1",
    "duckdb": "1.4.4",
    "express": "4.22.1",
    "geojson-vt": "3.2.1",
    "h3-js": "4.4.0",
    "vt-pbf": "3.1.3"
  },
  "devDependencies": {
    "@types/express": "5.0.6",
    "@types/node": "24.12.0",
    "typescript": "5.9.3",
    "tsx": "4.21.0"
  }
}
