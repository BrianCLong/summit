{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "item": { "type": "string" },
    "evidence": {
      "type": "object",
      "patternProperties": {
        "^EVD-[A-Z0-9-]+$": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  },
  "required": ["item", "evidence"]
}
