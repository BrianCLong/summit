{
  "$id": "https://summit.dev/schemas/pg.action.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PG ObservedActionSignature",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "label", "indicators", "provenance"],
  "properties": {
    "id": { "type": "string", "minLength": 3 },
    "label": { "type": "string", "minLength": 3 },
    "description": { "type": "string" },

    "indicators": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "signal", "weight"],
        "properties": {
          "id": { "type": "string" },
          "signal": { "type": "string", "minLength": 3 },
          "weight": { "type": "number", "minimum": 0, "maximum": 1 },
          "evidenceKinds": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },

    "constraints": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "description"],
        "properties": {
          "id": { "type": "string" },
          "description": { "type": "string", "minLength": 3 }
        }
      }
    },

    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "createdAt", "curator"],
      "properties": {
        "source": { "type": "string", "minLength": 3 },
        "createdAt": { "type": "string", "format": "date-time" },
        "curator": { "type": "string", "minLength": 2 },
        "references": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
