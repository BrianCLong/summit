{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://summit.local/schema/civilizationReality.schema.json",
  "title": "CivilizationGroup",
  "type": "object",
  "required": ["id", "name"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "historicalNarratives": { "type": "array", "items": { "type": "string" } },
    "mythicSymbols": { "type": "array", "items": { "type": "string" } },
    "identityMemories": { "type": "array", "items": { "type": "string" } },
    "longTermValueSystems": { "type": "array", "items": { "type": "string" } },
    "metadata": { "type": "object", "additionalProperties": true }
  },
  "additionalProperties": false
}
