{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://summit.local/schema/culturalReality.schema.json",
  "title": "PopulationGroup",
  "type": "object",
  "required": ["id", "name", "regionId", "h3Cells", "languages"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "regionId": { "type": "string", "minLength": 1 },
    "h3Cells": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "languages": { "type": "array", "items": { "type": "string" } },
    "dialects": { "type": "array", "items": { "type": "string" } },
    "religions": { "type": "array", "items": { "type": "string" } },
    "ageBands": { "type": "object", "additionalProperties": { "type": "number" } },
    "educationDistribution": { "type": "object", "additionalProperties": { "type": "number" } },
    "economicProfile": { "type": "string" },
    "mediaConsumption": { "type": "array", "items": { "type": "string" } },
    "historicalMemories": { "type": "array", "items": { "type": "string" } },
    "valueSignals": { "type": "array", "items": { "type": "string" } },
    "trustProfiles": { "type": "object", "additionalProperties": { "type": "number" } },
    "metadata": { "type": "object", "additionalProperties": true }
  },
  "additionalProperties": false
}
