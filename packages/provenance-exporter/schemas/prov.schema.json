{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://summit.intelgraph.io/schemas/prov.schema.json",
    "type": "object",
    "title": "Summit PROV-JSON Schema",
    "description": "A simplified W3C PROV-JSON schema for Summit artifact lineage.",
    "properties": {
        "prefix": {
            "type": "object",
            "additionalProperties": {
                "type": "string"
            }
        },
        "entity": {
            "type": "object",
            "patternProperties": {
                "^.*$": {
                    "type": "object",
                    "properties": {
                        "prov:type": {
                            "type": [
                                "string",
                                "object"
                            ]
                        },
                        "summit:sha256": {
                            "type": "string"
                        }
                    },
                    "required": [
                        "prov:type"
                    ]
                }
            }
        },
        "activity": {
            "type": "object",
            "patternProperties": {
                "^.*$": {
                    "type": "object",
                    "properties": {
                        "prov:startTime": {
                            "type": "string",
                            "format": "date-time"
                        },
                        "prov:endTime": {
                            "type": "string",
                            "format": "date-time"
                        },
                        "summit:runId": {
                            "type": "string"
                        }
                    },
                    "required": [
                        "prov:startTime",
                        "prov:endTime"
                    ]
                }
            }
        },
        "agent": {
            "type": "object",
            "patternProperties": {
                "^.*$": {
                    "type": "object",
                    "properties": {
                        "prov:type": {
                            "type": [
                                "string",
                                "object"
                            ]
                        },
                        "prov:label": {
                            "type": "string"
                        }
                    },
                    "required": [
                        "prov:type"
                    ]
                }
            }
        },
        "wasGeneratedBy": {
            "type": "object",
            "patternProperties": {
                "^.*$": {
                    "type": "object",
                    "properties": {
                        "prov:entity": {
                            "type": "string"
                        },
                        "prov:activity": {
                            "type": "string"
                        },
                        "prov:time": {
                            "type": "string",
                            "format": "date-time"
                        }
                    },
                    "required": [
                        "prov:entity",
                        "prov:activity"
                    ]
                }
            }
        },
        "wasAssociatedWith": {
            "type": "object",
            "patternProperties": {
                "^.*$": {
                    "type": "object",
                    "properties": {
                        "prov:activity": {
                            "type": "string"
                        },
                        "prov:agent": {
                            "type": "string"
                        },
                        "prov:plan": {
                            "type": "string"
                        }
                    },
                    "required": [
                        "prov:activity",
                        "prov:agent"
                    ]
                }
            }
        }
    },
    "required": [
        "prefix",
        "entity",
        "activity",
        "agent"
    ]
}