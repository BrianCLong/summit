{
  "$id": "https://summit.local/schemas/provenance.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Provenance",
  "type": "object",
  "required": ["producer", "generated_at", "pipeline", "hashes"],
  "properties": {
    "producer": {
      "type": "object",
      "required": ["kind", "id"],
      "properties": {
        "kind": { "type": "string", "enum": ["human", "agent", "system"] },
        "id": { "type": "string", "minLength": 1 },
        "display_name": { "type": "string" }
      },
      "additionalProperties": false
    },
    "generated_at": { "type": "string", "format": "date-time" },
    "pipeline": {
      "type": "object",
      "required": ["name", "version"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "model": { "type": "string" },
        "prompt_hash": { "type": "string" },
        "toolchain": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "hashes": {
      "type": "object",
      "required": ["writeset_sha256"],
      "properties": {
        "writeset_sha256": { "type": "string", "minLength": 16 },
        "artifact_sha256": { "type": "string" }
      },
      "additionalProperties": false
    },
    "signatures": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["alg", "sig"],
        "properties": {
          "alg": { "type": "string" },
          "kid": { "type": "string" },
          "sig": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
