{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "summit/writeset.schema.json",
  "type": "object",
  "required": [
    "writeSetId",
    "entityId",
    "memoryObjectId",
    "graphIntents",
    "tier",
    "eventTime",
    "ingestTime",
    "claimRefs",
    "embeddingRefs",
    "provenanceRefs",
    "confidence",
    "policyTags",
    "supersedes",
    "conflictsWith",
    "promotionState",
    "content"
  ],
  "properties": {
    "writeSetId": { "type": "string", "minLength": 1 },
    "entityId": { "type": "string", "minLength": 1 },
    "memoryObjectId": { "type": "string", "minLength": 1 },
    "graphIntents": {
      "type": "array",
      "items": { "enum": ["RG", "BG", "NG"] },
      "minItems": 1
    },
    "tier": {
      "enum": ["episode", "entity", "pattern", "doctrine"]
    },
    "eventTime": { "type": "string", "format": "date-time" },
    "ingestTime": { "type": "string", "format": "date-time" },
    "claimRefs": { "type": "array", "items": { "type": "string" } },
    "embeddingRefs": { "type": "array", "items": { "type": "string" } },
    "provenanceRefs": {
      "type": "array",
      "items": { "$ref": "summit/provenance.schema.json" }
    },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "policyTags": { "type": "array", "items": { "type": "string" } },
    "supersedes": { "type": "array", "items": { "type": "string" } },
    "conflictsWith": { "type": "array", "items": { "type": "string" } },
    "promotionState": {
      "enum": [
        "candidate",
        "linked",
        "validated",
        "promoted",
        "demoted",
        "quarantined",
        "archived"
      ]
    },
    "content": {
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "summary": { "type": "string" },
        "body": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
