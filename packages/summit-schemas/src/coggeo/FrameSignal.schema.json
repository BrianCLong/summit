{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "coggeo/FrameSignal.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "obs_id", "frame", "ts"],
  "properties": {
    "id": { "type": "string" },
    "obs_id": { "type": "string" },
    "frame": { "type": "string" },
    "ideological_anchor": { "type": ["string", "null"] },
    "ts": { "type": "string", "format": "date-time" }
  }
}
