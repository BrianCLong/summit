{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "coggeo/ExplainPayload.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "summary", "drivers", "confidence", "provenance"],
  "properties": {
    "id": { "type": "string" },
    "summary": { "type": "string" },
    "drivers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "delta", "evidence"],
        "properties": {
          "name": { "type": "string" },
          "delta": { "type": "number" },
          "evidence": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "provenance": {
      "type": "object",
      "required": ["models"],
      "properties": {
        "models": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
