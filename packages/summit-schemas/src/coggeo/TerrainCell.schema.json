{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "coggeo/TerrainCell.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "ts_bucket", "h3", "narrative_id", "pressure", "temperature"],
  "properties": {
    "id": { "type": "string" },
    "ts_bucket": { "type": "string" },
    "h3": { "type": "string" },
    "narrative_id": { "type": "string" },
    "pressure": { "type": "number" },
    "temperature": { "type": "number" },
    "wind_u": { "type": "number" },
    "wind_v": { "type": "number" },
    "turbulence": { "type": "number" },
    "storm_score": { "type": "number" }
  }
}
