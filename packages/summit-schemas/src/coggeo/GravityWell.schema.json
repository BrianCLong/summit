{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "coggeo/GravityWell.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "label", "strength", "capture_rate", "evidence_refs"],
  "properties": {
    "id": { "type": "string" },
    "label": { "type": "string" },
    "strength": { "type": "number", "minimum": 0, "maximum": 1 },
    "capture_rate": { "type": "number", "minimum": 0, "maximum": 1 },
    "evidence_refs": { "type": "array", "items": { "type": "string" } }
  }
}
