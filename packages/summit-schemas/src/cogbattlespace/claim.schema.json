{
  "$id": "https://schemas.summit.local/cogbattlespace/claim.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RealityClaim",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "statement", "status", "confidence", "evidenceRefs"],
  "properties": {
    "id": { "type": "string", "minLength": 8 },
    "statement": { "type": "string", "minLength": 8 },
    "status": { "type": "string", "enum": ["unverified", "verified", "disputed"] },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "evidenceRefs": { "type": "array", "items": { "type": "string" }, "default": [] }
  }
}
