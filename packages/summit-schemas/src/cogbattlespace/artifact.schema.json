{
  "$id": "https://schemas.summit.local/cogbattlespace/artifact.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Artifact",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "kind", "source", "observedAt", "content", "provenance"],
  "properties": {
    "id": { "type": "string", "minLength": 8 },
    "kind": {
      "type": "string",
      "enum": ["post", "article", "video", "image", "document", "transcript"]
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["platform", "uri"],
      "properties": {
        "platform": { "type": "string", "minLength": 2 },
        "uri": { "type": "string", "minLength": 8 }
      }
    },
    "observedAt": { "type": "string", "format": "date-time" },
    "content": {
      "type": "object",
      "additionalProperties": false,
      "required": ["text"],
      "properties": {
        "text": { "type": "string", "minLength": 1 },
        "language": { "type": "string", "minLength": 2 },
        "hash": { "type": "string" }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["collector", "collectedAt"],
      "properties": {
        "collector": { "type": "string", "minLength": 2 },
        "collectedAt": { "type": "string", "format": "date-time" },
        "chain": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        }
      }
    }
  }
}
