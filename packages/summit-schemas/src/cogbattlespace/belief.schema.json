{
  "$id": "https://schemas.summit.local/cogbattlespace/belief.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Belief",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "proposition", "polarity", "confidence", "timeSeries", "provenance"],
  "properties": {
    "id": { "type": "string", "minLength": 8 },
    "proposition": { "type": "string", "minLength": 8 },
    "polarity": { "type": "string", "enum": ["support", "oppose", "uncertain"] },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "timeSeries": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["t", "cohortId", "prevalence", "uncertainty"],
        "properties": {
          "t": { "type": "string", "format": "date-time" },
          "cohortId": { "type": "string", "minLength": 3 },
          "prevalence": { "type": "number", "minimum": 0, "maximum": 1 },
          "uncertainty": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      },
      "default": []
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["evidenceArtifacts", "estimator"],
      "properties": {
        "evidenceArtifacts": { "type": "array", "items": { "type": "string" }, "default": [] },
        "estimator": { "type": "string", "default": "observational-estimator-v0" }
      }
    }
  }
}
