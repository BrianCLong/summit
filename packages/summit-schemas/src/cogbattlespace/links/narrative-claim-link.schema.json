{
  "$id": "https://schemas.summit.local/cogbattlespace/links/narrative-claim-link.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "NarrativeClaimLink",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "narrativeId", "claimId", "type", "score", "observedAt", "provenance"],
  "properties": {
    "id": { "type": "string", "minLength": 8 },
    "narrativeId": { "type": "string" },
    "claimId": { "type": "string" },
    "type": { "type": "string", "enum": ["references", "contradicts", "misrepresents", "unclear"] },
    "score": { "type": "number", "minimum": 0, "maximum": 1 },
    "observedAt": { "type": "string", "format": "date-time" },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["method", "artifactIds"],
      "properties": {
        "method": { "type": "string", "default": "linker-v0" },
        "artifactIds": { "type": "array", "items": { "type": "string" }, "default": [] }
      }
    }
  }
}
