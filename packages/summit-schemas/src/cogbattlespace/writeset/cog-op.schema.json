{
  "$id": "https://schemas.summit.local/cogbattlespace/writeset/cog-op.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CogWriteOp",
  "type": "object",
  "additionalProperties": false,
  "required": ["opId", "domain", "entityType", "action", "payload"],
  "properties": {
    "opId": { "type": "string", "minLength": 6 },
    "domain": { "type": "string", "enum": ["NG", "BG"] },
    "entityType": {
      "type": "string",
      "enum": [
        "Artifact",
        "Narrative",
        "Belief",
        "NarrativeClaimLink",
        "BeliefClaimLink",
        "NarrativeBeliefLink",
        "DivergenceMetric",
        "BeliefGapMetric"
      ]
    },
    "action": { "type": "string", "enum": ["UPSERT", "APPEND", "MERGE", "DELETE"] },
    "payload": { "type": "object" },
    "hints": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "idempotencyKey": { "type": "string" },
        "ttlSeconds": { "type": "integer", "minimum": 1 },
        "priority": { "type": "integer", "minimum": 0, "maximum": 10 }
      }
    }
  }
}
