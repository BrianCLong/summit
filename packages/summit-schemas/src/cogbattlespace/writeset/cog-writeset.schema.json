{
  "$id": "https://schemas.summit.local/cogbattlespace/writeset/cog-writeset.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CogWriteSet",
  "type": "object",
  "additionalProperties": false,
  "required": ["kind", "version", "writesetId", "createdAt", "origin", "ops"],
  "properties": {
    "kind": { "type": "string", "const": "cog_writeset" },
    "version": { "type": "string", "const": "v1" },
    "writesetId": { "type": "string", "minLength": 8 },
    "createdAt": { "type": "string", "format": "date-time" },
    "origin": {
      "type": "object",
      "additionalProperties": false,
      "required": ["actor", "pipeline", "runId"],
      "properties": {
        "actor": { "type": "string", "minLength": 2 },
        "pipeline": { "type": "string", "minLength": 2 },
        "runId": { "type": "string", "minLength": 6 }
      }
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["allowDomains", "denyDomains"],
      "properties": {
        "allowDomains": { "type": "array", "items": { "type": "string", "enum": ["NG", "BG"] }, "minItems": 1 },
        "denyDomains": { "type": "array", "items": { "type": "string", "enum": ["RG"] }, "default": ["RG"] }
      },
      "default": { "allowDomains": ["NG", "BG"], "denyDomains": ["RG"] }
    },
    "ops": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "https://schemas.summit.local/cogbattlespace/writeset/cog-op.schema.json" }
    }
  }
}
