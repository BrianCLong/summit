{
  "$id": "https://schemas.summit.local/cogbattlespace/writeset/cog-rejection-report.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CogRejectionReport",
  "type": "object",
  "additionalProperties": false,
  "required": ["ok", "writesetId", "summary", "items"],
  "properties": {
    "ok": { "type": "boolean" },
    "writesetId": { "type": "string" },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["receivedOps", "acceptedOps", "rejectedOps"],
      "properties": {
        "receivedOps": { "type": "integer", "minimum": 0 },
        "acceptedOps": { "type": "integer", "minimum": 0 },
        "rejectedOps": { "type": "integer", "minimum": 0 }
      }
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["opId", "status"],
        "properties": {
          "opId": { "type": "string" },
          "status": { "type": "string", "enum": ["ACCEPTED", "REJECTED"] },
          "entityType": { "type": "string" },
          "domain": { "type": "string" },
          "action": { "type": "string" },
          "errors": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["code", "message"],
              "properties": {
                "code": { "type": "string" },
                "message": { "type": "string" },
                "instancePath": { "type": "string" },
                "schemaPath": { "type": "string" },
                "details": { "type": "object" }
              }
            },
            "default": []
          }
        }
      }
    }
  }
}
