{
  "$id": "https://schemas.summit.local/cogbattlespace/metrics/divergence-metric.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DivergenceMetric",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "narrativeId", "claimId", "divergenceScore", "asOf"],
  "properties": {
    "id": { "type": "string", "minLength": 8 },
    "narrativeId": { "type": "string" },
    "claimId": { "type": "string" },
    "divergenceScore": { "type": "number", "minimum": 0, "maximum": 1 },
    "asOf": { "type": "string", "format": "date-time" }
  }
}
