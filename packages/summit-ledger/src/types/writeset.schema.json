{
  "$id": "https://summit.local/schemas/writeset.schema.json",
  "type": "object",
  "required": ["writeset_id", "system_time", "source", "ops", "provenance"],
  "properties": {
    "writeset_id": { "type": "string" },
    "system_time": { "type": "string", "format": "date-time" },
    "source": { "type": "string" },
    "ops": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/Op" }
    },
    "provenance": { "$ref": "#/$defs/Provenance" }
  },
  "$defs": {
    "Provenance": {
      "type": "object",
      "required": ["artifacts"],
      "properties": {
        "artifacts": {
          "type": "array",
          "items": { "$ref": "#/$defs/ArtifactRef" }
        }
      }
    },
    "ArtifactRef": {
      "type": "object",
      "required": ["artifact_id", "type", "sha256"],
      "properties": {
        "artifact_id": { "type": "string" },
        "type": { "type": "string" },
        "sha256": { "type": "string" },
        "uri": { "type": "string" }
      }
    },
    "Bitemporal": {
      "type": "object",
      "required": ["valid_from"],
      "properties": {
        "valid_from": { "type": "string", "format": "date-time" },
        "valid_to": { "type": ["string", "null"], "format": "date-time" }
      }
    },
    "UpsertClaim": {
      "type": "object",
      "required": ["op", "graph", "claim"],
      "properties": {
        "op": { "const": "UPSERT_CLAIM" },
        "graph": { "enum": ["RG", "BG", "NG"] },
        "claim": {
          "type": "object",
          "required": ["claim_id", "subject", "predicate", "object", "confidence", "time", "evidence_ids"],
          "properties": {
            "claim_id": { "type": "string" },
            "subject": { "type": "string" },
            "predicate": { "type": "string" },
            "object": { "type": "string" },
            "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
            "time": { "$ref": "#/$defs/Bitemporal" },
            "evidence_ids": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        }
      }
    },
    "ProposePromotion": {
      "type": "object",
      "required": ["op", "promotion"],
      "properties": {
        "op": { "const": "PROPOSE_PROMOTION" },
        "promotion": {
          "type": "object",
          "required": ["promotion_id", "claim_id", "from_graph", "to_graph"],
          "properties": {
            "promotion_id": { "type": "string" },
            "claim_id": { "type": "string" },
            "from_graph": { "enum": ["BG", "NG"] },
            "to_graph": { "const": "RG" }
          }
        }
      }
    },
    "Op": {
      "oneOf": [
        { "$ref": "#/$defs/UpsertClaim" },
        { "$ref": "#/$defs/ProposePromotion" }
      ]
    }
  }
}
