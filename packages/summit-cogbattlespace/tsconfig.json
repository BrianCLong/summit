{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "declaration": true,
    "outDir": "dist",
    "strict": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node", "jest"],
    "paths": {
      "@intelgraph/summit-schemas": ["../summit-schemas/src/index.ts"]
    }
  },
  "include": ["src/**/*"]
}
