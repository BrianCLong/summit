name: "[info] AI Copilot Canary"
on:
  schedule:
    - cron: 15 * * * *
  workflow_dispatch: null
  push:
    paths:
      - slo/ai-copilot.yaml
      - RUNBOOKS/ai-copilot-service.md
      - services/ai-copilot/**
      - .github/workflows/ai-copilot-canary.yml
concurrency:
  group: ${{ github.workflow }}-${{ github.ref }}
  cancel-in-progress: true
jobs:
  canary:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - name: Install pnpm
        uses: pnpm/action-setup@v4
      - name: Setup Node
        uses: actions/setup-node@v4
        with:
          cache: pnpm
          node-version: "20"
      - name: Install dependencies (script only)
        run: pnpm add -w js-yaml
      - name: Run AI Copilot canary checks
        run: node scripts/ai-copilot-canary.cjs
    concurrency:
      group: ${{ github.workflow }}-${{ github.ref }}-${{ github.job }}
      cancel-in-progress: true
