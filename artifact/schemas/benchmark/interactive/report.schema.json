{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Interactive Benchmark Report",
  "type": "object",
  "properties": {
    "evidence_id": {
      "type": "string",
      "pattern": "^SUMMIT-IB-[a-zA-Z0-9_]+-[a-zA-Z0-9_]+-[0-9]+$"
    },
    "suite_id": { "type": "string" },
    "case_id": { "type": "string" },
    "agent_id": { "type": "string" },
    "success": { "type": "boolean" },
    "steps_taken": { "type": "integer" },
    "time_elapsed_ms": { "type": "integer" },
    "final_reward": { "type": "number" },
    "error": { "type": "string" }
  },
  "required": ["evidence_id", "suite_id", "case_id", "agent_id", "success", "steps_taken", "time_elapsed_ms", "final_reward"]
}
