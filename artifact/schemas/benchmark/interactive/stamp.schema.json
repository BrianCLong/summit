{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Interactive Benchmark Stamp",
  "type": "object",
  "properties": {
    "evidence_id": {
      "type": "string",
      "pattern": "^SUMMIT-IB-[a-zA-Z0-9_]+-[a-zA-Z0-9_]+-[0-9]+$"
    },
    "version": { "type": "string" },
    "git_sha": { "type": "string" },
    "suite_id": { "type": "string" },
    "seed": { "type": "integer" },
    "schema_version": { "type": "string" }
  },
  "required": ["evidence_id", "version", "git_sha", "suite_id", "seed", "schema_version"]
}
