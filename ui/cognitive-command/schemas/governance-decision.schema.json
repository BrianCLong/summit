{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "summit://schemas/governance-decision",
  "title": "GovernanceGate",
  "type": "object",
  "required": ["id", "name", "description", "status", "policyId", "triggerCondition", "riskLevel", "requiredApprovers", "createdAt"],
  "properties": {
    "id": { "type": "string", "format": "uuid" },
    "name": { "type": "string" },
    "description": { "type": "string" },
    "status": { "type": "string", "enum": ["open", "pending_approval", "approved", "rejected", "override"] },
    "policyId": { "type": "string" },
    "triggerCondition": { "type": "string" },
    "riskLevel": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
    "requiredApprovers": { "type": "array", "items": { "type": "string" } },
    "currentApprovals": { "type": "array", "items": { "$ref": "#/definitions/ApprovalRecord" } },
    "forecastedRisk": { "type": "number", "minimum": 0, "maximum": 1 },
    "constraints": { "type": "array", "items": { "type": "string" } },
    "linkedDecisionId": { "type": "string" },
    "linkedMissionId": { "type": "string" },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" },
    "deadline": { "type": "string", "format": "date-time" },
    "auditTrail": { "type": "array", "items": { "type": "object" } }
  },
  "definitions": {
    "ApprovalRecord": {
      "type": "object",
      "required": ["approverId", "decision", "rationale", "timestamp"],
      "properties": {
        "approverId": { "type": "string" },
        "decision": { "type": "string", "enum": ["approved", "rejected", "abstained"] },
        "rationale": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "conditions": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
