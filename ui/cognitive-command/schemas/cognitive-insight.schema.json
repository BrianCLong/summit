{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "summit://schemas/cognitive-insight",
  "title": "CognitiveInsight",
  "type": "object",
  "required": ["id", "title", "description", "category", "urgency", "confidence", "impact", "source", "explanation", "status", "createdAt"],
  "properties": {
    "id": { "type": "string", "format": "uuid" },
    "title": { "type": "string" },
    "description": { "type": "string" },
    "category": { "type": "string", "enum": ["anomaly", "hidden_relationship", "threat_signal", "forecast_shift", "narrative_shift", "mission_blocker", "intervention_opportunity", "governance_concern"] },
    "urgency": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "impact": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
    "source": { "type": "string" },
    "explanation": { "type": "string" },
    "evidenceIds": { "type": "array", "items": { "type": "string" } },
    "linkedEntityIds": { "type": "array", "items": { "type": "string" } },
    "linkedMissionIds": { "type": "array", "items": { "type": "string" } },
    "linkedForecastIds": { "type": "array", "items": { "type": "string" } },
    "linkedNarrativeIds": { "type": "array", "items": { "type": "string" } },
    "status": { "type": "string", "enum": ["new", "triaged", "investigating", "actioned", "dismissed"] },
    "triagedBy": { "type": "string" },
    "triagedAt": { "type": "string", "format": "date-time" },
    "createdAt": { "type": "string", "format": "date-time" },
    "relatedInsightIds": { "type": "array", "items": { "type": "string" } }
  }
}
