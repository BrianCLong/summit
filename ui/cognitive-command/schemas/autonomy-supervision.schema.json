{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "summit://schemas/autonomy-supervision",
  "title": "AutonomousTask",
  "type": "object",
  "required": ["id", "agentId", "taskDescription", "status", "confidence", "evidenceCount", "model", "runtime", "policyState", "priority", "startedAt"],
  "properties": {
    "id": { "type": "string", "format": "uuid" },
    "agentId": { "type": "string" },
    "taskDescription": { "type": "string" },
    "status": { "type": "string", "enum": ["idle", "running", "paused", "completed", "failed", "awaiting_approval", "escalated"] },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "evidenceCount": { "type": "integer", "minimum": 0 },
    "model": { "type": "string" },
    "runtime": { "type": "string" },
    "recentActions": { "type": "array", "items": { "type": "object" } },
    "policyState": { "type": "string", "enum": ["compliant", "warning", "violation", "pending_review"] },
    "escalationReason": { "type": "string" },
    "missionId": { "type": "string" },
    "priority": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
    "startedAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" },
    "completedAt": { "type": "string", "format": "date-time" },
    "outputs": { "type": "array", "items": { "type": "object" } },
    "toolUsage": { "type": "array", "items": { "type": "object" } },
    "safetyBoundaries": { "type": "array", "items": { "type": "object" } }
  }
}
