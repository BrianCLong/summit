    "@types/cors": "2.8.0",
    "@types/compression": "1.7.0",
    "@types/node": "20.19.27",
    "typescript": "5.9.3",
    "tsx": "4.7.0",
    "jest": "30.2.0",
    "@types/jest": "30.0.0",
    "eslint": "9.39.2",
    "@typescript-eslint/eslint-plugin": "8.46.4",
    "@typescript-eslint/parser": "8.46.4"
  },
  "type": "module",
