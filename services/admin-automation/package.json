{
  "name": "@intelgraph/admin-automation",
  "version": "4.2.3",
  "description": "AI-driven administrative task automation for 70% workload reduction",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
  },
  "devDependencies": {
    "@types/cors": "2.8.19",
    "@types/express": "4.17.25",
    "@types/node": "20.0.0",
    "@types/uuid": "9.0.0",
    "tsx": "4.0.0",
    "typescript": "5.3.3",
    "vitest": "1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
