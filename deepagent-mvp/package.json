{
  "name": "deepagent-mvp",
  "version": "4.2.3",
  "description": "DeepAgent-style MVP for IntelGraph",
  "main": "dist/index.js",
  "scripts": {
    "prestart": "docker run --rm -v $(pwd)/src/agent/policies:/policies openpolicyagent/opa build -t wasm -e deepagent/authz /policies/opa.rego > src/agent/policies/policy.wasm",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "k6": "k6 run tests/k6/script.js"
  },
  "keywords": [
    "deepagent",
    "intelgraph",
    "agent",
    "graphql",
    "typescript"
  ],
  "author": "Jules",
  "license": "SEE LICENSE IN LICENSE",
  "dependencies": {
  },
  "devDependencies": {
    "@types/cors": "2.8.16",
    "@types/express": "4.17.21",
    "@types/jest": "29.5.8",
    "@types/jsonwebtoken": "9.0.5",
    "@types/node": "20.9.0",
    "@types/pg": "8.10.9",
    "@types/uuid": "9.0.7",
    "@types/ws": "8.5.8",
    "eslint": "8.53.0",
    "eslint-config-prettier": "9.0.0",
    "eslint-plugin-prettier": "5.0.1",
    "jest": "29.7.0",
    "jsonwebtoken": "9.0.2",
    "nock": "13.3.3",
    "prettier": "3.1.0",
    "socket.io-client": "4.8.1",
    "ts-jest": "29.1.1",
    "typescript": "5.2.2"
  }
}
