# ====================== Core ======================
NODE_ENV=development
PORT=4000

# ====================== Databases ======================
POSTGRES_DB=summit_dev
POSTGRES_USER=summit
POSTGRES_PASSWORD=super-secret-postgres-pass-2026

DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

# Neo4j
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=super-secret-neo4j-pass-2026
NEO4J_URI=bolt://neo4j:7687

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Elasticsearch (dev)
ELASTICSEARCH_URL=http://elasticsearch:9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=devpassword

# ====================== Auth & Security ======================
JWT_SECRET=change-this-to-64-random-chars-minimum-please
JWT_REFRESH_SECRET=another-64-random-chars
SESSION_SECRET=yet-another-64-random-chars

# ====================== AI (uncomment + add your keys) ======================
AI_ENABLED=true
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GROQ_API_KEY=gsk_...
# GROK_API_KEY=...

# ====================== Observability ======================
OTEL_SERVICE_NAME=summit
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318

# ====================== Dev-only ======================
ENABLE_INSECURE_DEV_AUTH=true
CORS_ORIGIN=http://localhost:3000
RATE_LIMIT_MAX=600
RATE_LIMIT_WINDOW_MS=60000

# ====================== WebSocket ======================
VITE_API_URL=http://localhost:4000/graphql
VITE_WS_URL=ws://localhost:4000/graphql
