{
  "name": "intelgraph-server",
  "version": "4.1.4",
  "private": true,
  "scripts": {
    "start": "node dist/server/src/index.js",
    "dev": "nodemon --exec ts-node src/index.ts",
    "build": "tsc",
    "test": "npx jest",
    "test:watch": "npx jest --watch",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write \"src/**/*.{ts,json}\"",
    "migrate": "npx tsx scripts/managed-migrate.ts up",
    "migrate:down": "npx tsx scripts/managed-migrate.ts down"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "pino": "^8.16.1",
    "pino-pretty": "^10.2.3",
    "dotenv": "^16.3.1",
    "pg": "^8.11.3",
    "redis": "^4.6.10",
    "neo4j-driver": "^5.14.0",
    "jsonwebtoken": "^9.0.2",
    "bcrypt": "^5.1.1",
    "zod": "^3.22.4",
    "ws": "^8.14.2",
    "uuid": "^9.0.1",
    "@intelgraph/osint-collector": "workspace:*",
    "@intelgraph/context-shell": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.2.2",
    "ts-node": "^10.9.1",
    "@types/node": "^20.8.10",
    "@types/express": "^4.17.20",
    "@types/cors": "^2.8.15",
    "@types/morgan": "^1.9.7",
    "@types/pg": "^8.10.7",
    "@types/jsonwebtoken": "^9.0.4",
    "@types/bcrypt": "^5.0.1",
    "@types/ws": "^8.5.8",
    "@types/uuid": "^9.0.6",
    "nodemon": "^3.0.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "@types/jest": "^29.5.6",
    "eslint": "^8.52.0",
    "@typescript-eslint/parser": "^6.9.1",
    "@typescript-eslint/eslint-plugin": "^6.9.1",
    "prettier": "^3.0.3",
    "tsx": "^4.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
