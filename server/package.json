{
  "name": "@summit/server",
  "version": "4.2.3",
  "private": true,
  "description": "Summit Server Application",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "npx tsc",
    "start": "node dist/index.js",
    "dev": "npx tsx watch src/index.ts",
    "test": "npx jest",
    "test:unit": "npx jest --testPathIgnorePatterns='integration'",
    "test:integration": "npx jest --testPathIgnorePatterns='[]' --testMatch='**/*.integration.test.ts'",
    "lint": "npx eslint src/"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "zod": "^3.22.4",
    "dotenv": "^16.4.5",
    "ioredis": "^5.3.2",
    "neo4j-driver": "^5.17.0",
    "prom-client": "^15.1.0",
    "winston": "^3.11.0",
    "@aws-sdk/client-s3": "^3.525.0",
    "@summit/cache": "workspace:*",
    "nanoid": "^3.3.7"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.11.24",
    "@types/jest": "^29.5.12",
    "@types/supertest": "^6.0.2",
    "typescript": "^5.3.3",
    "tsx": "^4.7.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "supertest": "^6.3.4",
    "eslint": "^8.57.0",
    "@typescript-eslint/parser": "^7.1.0",
    "@typescript-eslint/eslint-plugin": "^7.1.0"
  },
  "engines": {
    "node": ">=20"
  }
}
