{
  "title": "AI/ML Performance",
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "panels": [
    {
      "type": "stat",
      "title": "Active AI Jobs",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 0 },
      "targets": [
        { "expr": "sum(ai_jobs_processing)", "legendFormat": "Processing" },
        { "expr": "sum(ai_jobs_queued)", "legendFormat": "Queued" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Job Duration (P95)",
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 0 },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(ai_job_duration_seconds_bucket[5m])) by (le, job_type))", "legendFormat": "{{job_type}}" }
      ]
    },
    {
      "type": "timeseries",
      "title": "LLM Requests Rate",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        { "expr": "sum(rate(llm_requests_total[5m])) by (provider)", "legendFormat": "{{provider}}" }
      ]
    },
    {
      "type": "timeseries",
      "title": "LLM Tokens Processed",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        { "expr": "sum(rate(llm_tokens_total[5m])) by (model, type)", "legendFormat": "{{model}} - {{type}}" }
      ]
    }
  ]
}
