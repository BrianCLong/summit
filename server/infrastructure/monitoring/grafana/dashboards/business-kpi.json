{
  "title": "Business KPIs",
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "panels": [
    {
      "type": "stat",
      "title": "Total User Signups",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 0 },
      "targets": [
        { "expr": "sum(business_user_signups_total)", "legendFormat": "Signups" }
      ]
    },
    {
      "type": "stat",
      "title": "Total Revenue",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 0 },
      "targets": [
        { "expr": "sum(business_revenue_total)", "legendFormat": "Revenue" }
      ]
    },
    {
      "type": "timeseries",
      "title": "API Calls Rate",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 6 },
      "targets": [
        { "expr": "sum(rate(business_api_calls_total[5m])) by (service)", "legendFormat": "{{service}}" }
      ]
    }
  ]
}
