{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "..",
    "composite": true,
    "tsBuildInfoFile": "./dist/tsconfig.tsbuildinfo",
    "baseUrl": ".",
    "paths": {
      "@intelgraph/*": ["../packages/*/src"]
    }
  },
  "include": [
    "src/**/*",
    "tests/**/*",
    "scripts/**/*",
    "../packages/osint-collector/src/**/*",
    "../libs/context-shell/node/**/*"
  ],
  "exclude": ["node_modules", "dist", "coverage"]
}
