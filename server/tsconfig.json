{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "target": "ES2020",
    "outDir": "dist",
    "rootDir": "../..",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "esModuleInterop": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "strict": false
  },
  "include": [
    "src/**/*",
    "../../packages/osint-collector/src/**/*",
    "../../libs/context-shell/node/**/*"
  ],
  "exclude": [
    "node_modules",
    "**/*.test.ts"
  ]
}
