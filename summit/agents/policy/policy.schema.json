{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://summit.local/agents/policy.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "default", "rules"],
  "properties": {
    "version": {
      "type": "integer",
      "const": 1
    },
    "default": {
      "type": "string",
      "enum": ["deny"]
    },
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "when", "allow"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "allow": {
            "type": "boolean"
          },
          "when": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "agent_names": { "type": "array", "items": { "type": "string" } },
              "roles": {
                "type": "array",
                "items": { "enum": ["planner", "builder", "reviewer", "governance"] }
              },
              "skills": { "type": "array", "items": { "type": "string" } },
              "envs": {
                "type": "array",
                "items": { "enum": ["test", "dev", "prod"] }
              },
              "repo_paths_glob": { "type": "array", "items": { "type": "string" } },
              "dataset_ids": { "type": "array", "items": { "type": "string" } },
              "connector_ids": { "type": "array", "items": { "type": "string" } }
            }
          }
        }
      }
    }
  }
}
