{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "EvidenceReport",
  "type": "object",
  "required": ["evidence_id", "item", "summary", "artifacts"],
  "properties": {
    "evidence_id": {
      "type": "string"
    },
    "item": {
      "type": "object",
      "required": ["name", "source"],
      "properties": {
        "name": { "type": "string" },
        "source": { "type": "string" }
      }
    },
    "summary": { "type": "string" },
    "artifacts": {
      "type": "object",
      "required": ["report_json", "metrics_json", "stamp_json"],
      "properties": {
        "report_json": { "type": "string" },
        "metrics_json": { "type": "string" },
        "stamp_json": { "type": "string" }
      }
    }
  },
  "additionalProperties": false
}
