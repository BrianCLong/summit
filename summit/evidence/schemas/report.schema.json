{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Summit Evidence Report",
  "type": "object",
  "required": ["evidence_id","skillpack_id","summary","findings"],
  "additionalProperties": false,
  "properties": {
    "evidence_id": { "type": "string", "pattern": "^EVD-[A-Z0-9-]+-[0-9]{3}$" },
    "skillpack_id": { "type": "string" },
    "summary": { "type": "string" },
    "findings": { "type": "array", "items": { "type": "object", "required": ["severity","message"], "properties": {
      "severity": { "type": "string", "enum": ["critical","important","nice_to_have","info"] },
      "message": { "type": "string" },
      "path": { "type": "string" }
    }, "additionalProperties": false } }
  }
}
