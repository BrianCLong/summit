{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Summit Skillpack",
  "type": "object",
  "required": ["id", "name", "version", "owner", "enabled", "permissions", "inputs", "outputs"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{2,63}$" },
    "name": { "type": "string", "minLength": 3 },
    "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "owner": { "type": "string", "minLength": 2 },
    "enabled": { "type": "boolean" },
    "description": { "type": "string" },
    "triggers": { "type": "array", "items": { "type": "string" } },
    "data_classification": { "type": "string", "enum": ["public","internal","confidential","restricted"] },
    "never_log_fields": { "type": "array", "items": { "type": "string" } },
    "permissions": {
      "type": "object",
      "required": ["network", "filesystem_write", "allowed_tools"],
      "additionalProperties": false,
      "properties": {
        "network": { "type": "boolean" },
        "filesystem_write": { "type": "boolean" },
        "allowed_tools": { "type": "array", "items": { "type": "string" } }
      }
    },
    "inputs": { "type": "array", "items": { "type": "object", "required": ["name","type"], "properties": {
      "name": { "type": "string" }, "type": { "type": "string" }, "required": { "type": "boolean" }
    }, "additionalProperties": false } },
    "outputs": { "type": "array", "items": { "type": "object", "required": ["name","type"], "properties": {
      "name": { "type": "string" }, "type": { "type": "string" }
    }, "additionalProperties": false } }
  }
}
