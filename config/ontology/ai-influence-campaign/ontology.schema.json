{
  "$id": "summit.ai-influence-campaign.ontology.v0",
  "type": "object",
  "required": ["campaign_id", "actor_ids", "objectives", "tactics", "evidence"],
  "properties": {
    "campaign_id": { "type": "string", "pattern": "^camp_[a-z0-9_\\-]+$" },
    "actor_ids": {
      "type": "array",
      "items": { "type": "string", "pattern": "^actor_[a-z0-9_\\-]+$" },
      "minItems": 1
    },
    "objectives": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "tactics": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["tactic_id", "technique_ids"],
        "properties": {
          "tactic_id": { "type": "string" },
          "technique_ids": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "ai_usage": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["phase", "capability", "evidence_ids"],
        "properties": {
          "phase": { "type": "string" },
          "capability": { "type": "string" },
          "evidence_ids": { "type": "array", "items": { "type": "string" }, "minItems": 1 }
        }
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["evidence_id", "label"],
        "properties": {
          "evidence_id": { "type": "string", "pattern": "^EVID:ai-influence-campaign:[a-z]+:[0-9]{4}$" },
          "label": { "type": "string" }
        }
      },
      "minItems": 1
    }
  }
}
