{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://summit.dev/schemas/in-toto/layout.schema.json",
  "title": "Summit Stage Provenance Layout",
  "type": "object",
  "required": [
    "type",
    "version",
    "steps"
  ],
  "properties": {
    "type": {
      "const": "layout"
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "expectedMaterials": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "signers": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
