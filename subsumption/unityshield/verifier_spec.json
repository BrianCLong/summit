{
  "name": "UnityShield Subsumption Verifier",
  "slug": "unityshield",
  "version": "1.0.0",
  "bundle_path": "subsumption/unityshield/",
  "required_files": [
    "manifest.yaml",
    "claims.md",
    "MASTER_PLAN.md",
    "CONVERGENCE_PROTOCOL.md",
    "prompts/A_Codex_Foundation.md",
    "prompts/B_Aegis_Policy.md",
    "prompts/C_Maestro_Performance.md",
    "prompts/D_Codex_Innovation.md",
    "prompts/E_Antigravity_Convergence.md"
