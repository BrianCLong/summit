{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://summit.local/evidence/claude_plugin_report.schema.json",
  "title": "Claude Plugin Assurance Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "report_type",
    "plugin_id",
    "version",
    "risk_score",
    "risk_level",
    "blocked",
    "findings",
    "deterministic_hash"
  ],
  "properties": {
    "report_type": {
      "const": "claude_plugin_assurance"
    },
    "plugin_id": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "risk_score": {
      "type": "integer",
      "minimum": 0
    },
    "risk_level": {
      "type": "string",
      "enum": [
        "low",
        "moderate",
        "high",
        "critical"
      ]
    },
    "blocked": {
      "type": "boolean"
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "severity",
          "message"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "severity": {
            "type": "string",
            "enum": [
              "low",
              "moderate",
              "high",
              "critical"
            ]
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "deterministic_hash": {
      "type": "string"
    }
  }
}
