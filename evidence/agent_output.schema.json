{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Agent Output Evidence",
  "type": "object",
  "required": [
    "evidence_id",
    "agent_model",
    "prompt_hash",
    "input_hash",
    "output_hash",
    "evaluation_score"
  ],
  "properties": {
    "evidence_id": {
      "type": "string",
      "minLength": 1
    },
    "agent_model": {
      "type": "string",
      "minLength": 1
    },
    "prompt_hash": {
      "type": "string",
      "minLength": 1
    },
    "input_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "output_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "evaluation_score": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0
    }
  },
  "additionalProperties": true
}

