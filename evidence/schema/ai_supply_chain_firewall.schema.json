{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AI Supply Chain Firewall Evidence",
  "type": "object",
  "properties": {
    "evidence_id": { "type": "string" },
    "item_slug": { "type": "string" },
    "patterns": {
      "type": "array",
      "items": { "type": "string" }
    },
    "claims": {
      "type": "array",
      "items": { "type": "string" }
    },
    "assessments": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "dependency": { "type": "string" },
          "risk_score": { "type": "number" },
          "reasons": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "required": ["dependency", "risk_score", "reasons"]
      }
    }
  },
  "required": ["evidence_id", "item_slug", "patterns", "claims", "assessments"]
}
