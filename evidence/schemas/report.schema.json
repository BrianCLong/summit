{
  "$id": "https://summit/evidence/report.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Summit Evidence Report",
  "oneOf": [
    {
      "type": "object",
      "required": ["summary", "scenarios", "status"],
      "properties": {
        "evidence_id": { "type": "string" },
        "summary": { "type": "string" },
        "scenarios": { "type": "integer", "minimum": 0 },
        "status": { "type": "string" },
        "item": { "type": "string" }
      },
      "additionalProperties": true
    },
    {
      "type": "object",
      "required": ["evidence_id", "item", "summary", "artifacts"],
      "properties": {
        "evidence_id": {
          "type": "string",
          "pattern": "^EVD-software-factory-[A-Z]+-[0-9]{3}$"
        },
        "item": {
          "type": "object",
          "required": ["source", "date"],
          "properties": {
            "source": { "type": "string" },
            "date": { "type": "string" }
          },
          "additionalProperties": false
        },
        "summary": { "type": "string" },
        "artifacts": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    }
  ]
}
