{
  "$id": "https://summit/evidence/report.schema.json",
  "type": "object",
  "required": ["evidence_id", "item", "summary", "artifacts"],
  "properties": {
    "evidence_id": {
      "type": "string",
      "pattern": "^EVD-software-factory-[A-Z]+-[0-9]{3}$"
    },
    "item": {
      "type": "object",
      "required": ["source", "date"],
      "properties": {
        "source": { "type": "string" },
        "date": { "type": "string" }
      },
      "additionalProperties": false
    },
    "summary": { "type": "string" },
    "artifacts": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false
}
