{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["evidence_id", "area"],
  "properties": {
    "evidence_id": {
      "type": "string",
      "pattern": "^EVD-[A-Z0-9]+-[A-Z0-9]+-[0-9]{3}$"
    },
    "area": {
      "type": "string"
    },
    "content": {
      "type": "object"
    }
  },
  "additionalProperties": true
}
