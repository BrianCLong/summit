{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Summit Evidence Report",
  "type": "object",
  "anyOf": [
    {
      "required": ["evidence_id", "area", "status", "artifacts"]
    },
    {
      "required": ["summary", "status"]
    }
  ],
  "properties": {
    "evidence_id": { "type": "string", "pattern": "^EVD-[A-Z0-9-]+$" },
    "area": { "type": "string" },
    "status": {
      "type": "string",
      "enum": ["pass", "fail", "PASS", "FAIL"]
    },
    "artifacts": { "type": "array", "items": { "type": "string" } },
    "summary": { "type": "string" },
    "scenarios": { "type": "integer" },
    "item": { "type": "string" }
  },
  "additionalProperties": true
}
