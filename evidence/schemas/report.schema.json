{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://summit.local/schemas/evidence/report.schema.json",
  "title": "Summit evidence report",
  "type": "object",
  "required": ["summary", "status"],
  "properties": {
    "evidence_id": { "type": "string" },
    "summary": { "type": "string" },
    "status": { "type": "string" },
    "scenarios": { "type": "integer" },
    "item": { "type": "string" },
    "classification": {
      "type": "string",
      "enum": ["public", "internal", "restricted", "phi"]
    }
  },
  "additionalProperties": true
}
