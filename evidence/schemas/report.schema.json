{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://summit.local/schemas/report.schema.json",
  "title": "Summit Evidence Report",
  "type": "object",
  "properties": {
    "evidence_id": { "type": "string" },
    "item": { "type": ["string", "object"] },
    "summary": { "type": "string" },
    "artifacts": {
      "type": "array",
      "items": { "type": "string" }
    },
    "policy": {
      "type": "object",
      "properties": {
        "mode": { "type": "string" },
        "write_enabled": { "type": "boolean" }
      },
      "additionalProperties": true
    }
  },
  "required": ["evidence_id", "summary", "artifacts", "policy"],
  "additionalProperties": true
}
