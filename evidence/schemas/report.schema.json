{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["evidence_id"],
  "properties": {
    "evidence_id": { "type": "string", "pattern": "^EVD-[A-Z0-9]+-[A-Z0-9]+-[0-9]{3}$" },
    "item_slug": { "type": "string" },
    "claims": { "type": "array" },
    "summary": { "type": "object" },
    "decisions": { "type": "array" },
    "findings": { "type": "array" },
    "errors": { "type": "array" }
  },
  "additionalProperties": true
}
