{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["evidence_id", "item_slug", "summary", "decisions", "findings", "errors", "claims"],
  "properties": {
    "evidence_id": { "type": "string", "pattern": "^EVD-OSINTENTERPRISE-[A-Z0-9_]+-[0-9]{3}$" },
    "item_slug": { "type": "string" },
    "summary": { "type": "string" },
    "decisions": { "type": "array" },
    "findings": { "type": "array" },
    "errors": { "type": "array" },
    "claims": { "type": "array" }
  },
  "additionalProperties": true
}
