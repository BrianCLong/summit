{
  "$id": "https://summit/evidence/metrics.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Summit Evidence Metrics",
  "oneOf": [
    {
      "type": "object",
      "properties": {
        "evidence_id": { "type": "string" },
        "avg_latency_ms": { "type": "number" },
        "avg_fanout": { "type": "number" }
      },
      "required": ["avg_latency_ms", "avg_fanout"],
      "additionalProperties": true
    },
    {
      "type": "object",
      "required": ["satisfaction", "scenarios_total", "scenarios_passed"],
      "properties": {
        "satisfaction": { "type": "number", "minimum": 0, "maximum": 1 },
        "scenarios_total": { "type": "integer", "minimum": 0 },
        "scenarios_passed": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    }
  ]
}
