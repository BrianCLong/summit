{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "oneOf": [
    {
      "type": "object",
      "required": ["latency_ms_p95", "ead", "bias"],
      "properties": {
        "latency_ms_p95": { "type": "number" },
        "ead": {
          "type": "object",
          "properties": {
            "precision": { "type": "number" },
            "recall": { "type": "number" }
          }
        },
        "bias": {
          "type": "object",
          "properties": {
            "by_language": { "type": "object" },
            "by_region": { "type": "object" },
            "by_demographic_proxy": { "type": "object" }
          }
        }
      }
    },
    {
      "type": "object",
      "required": ["scorecard_id", "scores", "rollup"],
      "properties": {
        "scorecard_id": { "type": "string", "pattern": "^COGDEF-SCORECARD-[0-9]{4}W[0-9]{2}$" },
        "scores": {
          "type": "array",
          "items": {
             "type": "object",
             "required": ["metric_id","name","pillar","score","confidence","coverage","evidence_refs"]
          }
        },
        "rollup": { "type": "object" },
        "notes": { "type": "string" }
      }
    }
  ]
}
