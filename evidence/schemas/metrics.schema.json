{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://summit.local/schemas/metrics.schema.json",
  "title": "Summit Evidence Metrics",
  "type": "object",
  "properties": {
    "docs_scanned": { "type": "number", "minimum": 0 },
    "docs_emitted": { "type": "number", "minimum": 0 },
    "excluded_paths": { "type": "number", "minimum": 0 },
    "duration_ms": { "type": "number", "minimum": 0 }
  },
  "required": ["docs_scanned", "docs_emitted", "excluded_paths", "duration_ms"],
  "additionalProperties": true
}
