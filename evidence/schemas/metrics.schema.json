{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "model_version": {
      "type": "string"
    },
    "weights": {
      "type": "object"
    },
    "scores": {
      "type": "object",
      "patternProperties": {
        "^.*$": {
          "type": "object",
          "required": ["score_total"],
          "properties": {
            "score_total": {
              "type": "number"
            },
            "subscores": {
              "type": "object"
            }
          },
          "additionalProperties": true
        }
      }
    }
  },
  "additionalProperties": true
}
