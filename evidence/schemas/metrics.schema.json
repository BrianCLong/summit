{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Summit Evidence Metrics",
  "type": "object",
  "anyOf": [
    {
      "required": ["evidence_id", "metrics"]
    },
    {
      "required": ["avg_latency_ms", "avg_fanout"]
    }
  ],
  "properties": {
    "evidence_id": { "type": "string" },
    "metrics": {
      "type": "object",
      "additionalProperties": { "type": "number" }
    },
    "avg_latency_ms": { "type": "number" },
    "avg_fanout": { "type": "number" }
  },
  "additionalProperties": true
}
