{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["evidence_id"],
  "properties": {
    "evidence_id": { "type": "string", "pattern": "^EVD-AIINFOPS-[A-Z]+-\\d{3}$" },
    "counters": {
      "type": "object",
      "additionalProperties": { "type": "number" }
    },
    "latency_ms": {
      "type": "object",
      "additionalProperties": { "type": "number" }
    }
  },
  "additionalProperties": false
}
