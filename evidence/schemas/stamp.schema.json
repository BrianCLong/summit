{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["evidence_id", "created_utc", "tool"],
  "properties": {
    "evidence_id": { "type": "string", "pattern": "^EVD-[A-Z0-9]+-[A-Z0-9]+-[0-9]{3}$" },
    "created_utc": { "type": "string", "format": "date-time" },
    "tool": { "type": "string" }
  },
  "additionalProperties": true
}
