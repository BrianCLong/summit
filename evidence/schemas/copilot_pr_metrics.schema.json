{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://summit.dev/evidence/schemas/copilot_pr_metrics.schema.json",
  "title": "Copilot PR Metrics Evidence",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "evidence_id",
    "item",
    "metrics",
    "schema_version",
    "source"
  ],
  "properties": {
    "evidence_id": {
      "type": "string",
      "const": "EVIDENCE-GH-COPILOT-PR-001"
    },
    "item": {
      "type": "string",
      "const": "github-copilot-pr-metrics-2026"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "source": {
      "type": "string",
      "const": "github.copilot.usage_metrics_api"
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pr_throughput",
        "time_to_merge_hours"
      ],
      "properties": {
        "pr_throughput": {
          "type": [
            "number",
            "null"
          ]
        },
        "time_to_merge_hours": {
          "type": [
            "number",
            "null"
          ]
        }
      }
    }
  }
}
