{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["bundle_version", "evidence"],
  "properties": {
    "bundle_version": {"type": "string"},
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["evidence_id", "path"],
        "properties": {
          "evidence_id": {"type": "string", "pattern": "^EVD-OSINTPRIMARYSENSOR-[A-Z]+-[0-9]{3}$"},
          "path": {"type": "string"}
        }
      }
    }
  },
  "additionalProperties": false
}
