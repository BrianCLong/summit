{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Evidence Index",
  "type": "object",
  "required": ["items"],
  "properties": {
    "version": { "type": ["string", "number"] },
    "items": {
      "type": "object",
      "patternProperties": {
        "^EVD-.*$": {
          "type": "object",
          "properties": {
            "title": { "type": "string" },
            "category": { "type": "string" },
            "files": {
              "type": "array",
              "items": { "type": "string" }
            },
            "artifacts": {
              "type": "array",
              "items": { "type": "string" }
            }
          },
          "anyOf": [
            { "required": ["files"] },
            { "required": ["artifacts"] }
          ],
          "additionalProperties": true
        }
      }
    }
  },
  "additionalProperties": true
}
