{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["version", "items"],
  "properties": {
    "version": {
      "type": "integer"
    },
    "items": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/definitions/EvidenceItem"
      }
    }
  },
  "definitions": {
    "EvidenceItem": {
      "type": "object",
      "required": ["evidence_id", "files"],
      "properties": {
        "evidence_id": {
          "type": "string"
        },
        "files": {
          "type": "object",
          "properties": {
            "report": {
              "type": "string"
            },
            "metrics": {
              "type": "string"
            },
            "stamp": {
              "type": "string"
            }
          },
          "required": ["report"]
        }
      }
    }
  }
}
