{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Evidence Index",
  "type": "object",
  "properties": {
    "version": { "type": "string" },
    "items": {
      "oneOf": [
        {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "path": { "type": "string" }
            },
            "required": ["id", "path"]
          }
        },
        {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      ]
    },
    "mappings": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["report", "metrics", "stamp"],
        "properties": {
          "report": { "type": "string" },
          "metrics": { "type": "string" },
          "stamp": { "type": "string" }
        }
      }
    }
  },
  "required": ["version", "items"]
}
