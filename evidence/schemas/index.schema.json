{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://summit.ai/schemas/evidence-index",
  "type": "object",
  "properties": {
    "items": {
      "type": "object",
      "patternProperties": {
        "^[a-zA-Z0-9_-]+$": {
          "$ref": "#/definitions/evidenceItem"
        }
      }
    }
  },
  "required": ["items"],
  "definitions": {
    "evidenceItem": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "deprecated", "archived"] },
        "description": { "type": "string" },
        "content": { "type": "object" }
      },
      "required": ["id", "status"]
    }
  }
}
