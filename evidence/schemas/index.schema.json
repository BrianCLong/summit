{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "items"
  ],
  "properties": {
    "items": {
      "type": ["object", "array"],
      "additionalProperties": {
        "$ref": "#/definitions/evidenceItem"
      }
    },
    "mappings": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["report", "metrics", "stamp"],
        "properties": {
          "report": { "type": "string" },
          "metrics": { "type": "string" },
          "stamp": { "type": "string" }
        }
      }
    },
    "evidence": {
      "type": "object"
    }
  },
  "definitions": {
    "evidenceItem": {
      "type": "object",
      "required": [
        "id",
        "status",
        "description"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "pending",
            "active",
            "deprecated"
          ]
        },
        "description": {
          "type": "string"
        }
      }
    }
  }
}
