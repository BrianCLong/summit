{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["evidence"],
  "properties": {
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "area", "files"],
        "properties": {
          "id": { "type": "string", "pattern": "^EVD-AIINFOPS-[A-Z]+-\\d{3}$" },
          "area": { "type": "string" },
          "files": {
            "type": "object",
            "required": ["report", "metrics", "stamp"],
            "properties": {
              "report": { "type": "string" },
              "metrics": { "type": "string" },
              "stamp": { "type": "string" }
            }
          }
        }
      }
    }
  },
  "additionalProperties": false
}
