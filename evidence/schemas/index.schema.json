{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["version", "items"],
  "properties": {
    "version": {
      "type": ["string", "integer"]
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["evidence_id"],
        "properties": {
          "evidence_id": {
            "type": "string"
          },
          "path": {
            "type": "string",
            "description": "Path to the evidence artifact if it is a single file."
          },
          "report": {
            "type": "string",
            "description": "Path to the report artifact."
          },
          "metrics": {
            "type": "string",
            "description": "Path to the metrics artifact."
          },
          "stamp": {
            "type": "string",
            "description": "Path to the stamp artifact."
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}
