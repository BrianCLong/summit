{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://summit.local/evidence/schema.json",
  "title": "Summit Golden Path Evidence Bundle",
  "type": "object",
  "required": [
    "build_id",
    "commit_sha",
    "policy_results",
    "test_results",
    "provenance",
    "timestamp"
  ],
  "additionalProperties": false,
  "properties": {
    "build_id": {
      "type": "string",
      "minLength": 1
    },
    "commit_sha": {
      "type": "string",
      "pattern": "^[a-f0-9]{7,40}$"
    },
    "policy_results": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "policy_name",
          "status",
          "severity",
          "evidence_ref"
        ],
        "additionalProperties": false,
        "properties": {
          "policy_name": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "pass",
              "fail",
              "warn"
            ]
          },
          "severity": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high",
              "critical"
            ]
          },
          "evidence_ref": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "test_results": {
      "type": "object",
      "required": [
        "status"
      ],
      "additionalProperties": true,
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "pass",
            "fail",
            "warn"
          ]
        }
      }
    },
    "provenance": {
      "type": "object",
      "required": [
        "repository",
        "workflow",
        "run_id",
        "run_attempt"
      ],
      "additionalProperties": true,
      "properties": {
        "repository": {
          "type": "string",
          "minLength": 1
        },
        "workflow": {
          "type": "string",
          "minLength": 1
        },
        "run_id": {
          "type": "string",
          "minLength": 1
        },
        "run_attempt": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    }
  }
}
