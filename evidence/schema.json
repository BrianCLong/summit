{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://summit.local/evidence/schema.json",
  "title": "SummitGoldenPathEvidenceBundle",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "build_id",
    "commit_sha",
    "policy_results",
    "test_results",
    "provenance",
    "timestamp"
  ],
  "properties": {
    "build_id": {
      "type": "string",
      "minLength": 1
    },
    "commit_sha": {
      "type": "string",
      "minLength": 7
    },
    "policy_results": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["policy_name", "status", "severity", "evidence_ref"],
        "properties": {
          "policy_name": { "type": "string" },
          "status": { "type": "string", "enum": ["pass", "fail", "warn"] },
          "severity": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
          "evidence_ref": { "type": "string" }
        }
      }
    },
    "test_results": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "status"],
        "properties": {
          "name": { "type": "string" },
          "status": { "type": "string", "enum": ["pass", "fail", "skip"] },
          "details": { "type": "string" }
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["workflow", "run_id", "repository"],
      "properties": {
        "workflow": { "type": "string" },
        "run_id": { "type": "string" },
        "repository": { "type": "string" }
      }
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    }
  }
}
