{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OpenLineage to PROV Mapping",
  "version": "1.44.1",
  "mapping": {
    "entities": [
      {
        "source": "event.inputs",
        "type": "prov:Entity",
        "idAttribute": "namespace + ':' + name",
        "attributes": {
          "schema": "facets.schema.fields",
          "symlinks": "facets.symlinks.identifiers"
        }
      },
      {
        "source": "event.outputs",
        "type": "prov:Entity",
        "idAttribute": "namespace + ':' + name",
        "attributes": {
          "schema": "facets.schema.fields",
          "symlinks": "facets.symlinks.identifiers"
        }
      }
    ],
    "activities": [
      {
        "source": "event.run",
        "type": "prov:Activity",
        "idAttribute": "runId",
        "attributes": {
          "startedAt": "event.eventTime",
          "extractionError": "facets.extractionError"
        }
      }
    ],
    "agents": [
      {
        "source": "event.job",
        "type": "prov:Agent",
        "idAttribute": "namespace + ':' + name",
        "attributes": {
          "jobType": "facets.jobType"
        }
      }
    ],
    "relations": [
      {
        "type": "prov:used",
        "activity": "event.run.runId",
        "entity": "event.inputs[].namespace + ':' + event.inputs[].name"
      },
      {
        "type": "prov:wasGeneratedBy",
        "entity": "event.outputs[].namespace + ':' + event.outputs[].name",
        "activity": "event.run.runId"
      },
      {
        "type": "prov:wasAssociatedWith",
        "activity": "event.run.runId",
        "agent": "event.job.namespace + ':' + event.job.name"
      }
    ]
  }
}
