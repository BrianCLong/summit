{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["schema_version", "run_id", "narrative", "config", "attempts_summary"],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0.0" },
    "run_id": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "narrative": { "type": "string" },
    "config": { "type": "object" },
    "attempts_summary": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["attempt_id", "status"],
        "properties": {
          "attempt_id": { "type": "string" },
          "status": { "type": "string" },
          "score": { "type": "number" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
