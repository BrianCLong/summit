{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "types": ["node", "express"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",
    "outDir": "dist-server",
    "noEmit": false,
    "allowImportingTsExtensions": false,
    "declaration": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true
  },
  "include": ["server"],
  "exclude": ["node_modules", "src", "test"]
}
