{
  "name": "@summit/summit-ui",
  "version": "0.1.0",
  "private": true,
  "description": "Summit Code UI – repo-scale workflow browser for humans",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n server,client -c cyan,magenta \"pnpm server:dev\" \"pnpm client:dev\"",
    "client:dev": "vite",
    "server:dev": "tsx watch server/index.ts",
    "build": "tsc -p tsconfig.build.json && vite build",
    "preview": "vite preview",
    "server": "node dist-server/index.js",
    "lint": "ESLINT_USE_FLAT_CONFIG=false eslint src server --ext .ts,.tsx",
    "lint:fix": "ESLINT_USE_FLAT_CONFIG=false eslint src server --ext .ts,.tsx --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "express": "^4.18.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/d3": "^7.4.3",
    "@types/express": "^4.17.21",
    "@types/hapi__catbox": "^12.1.0",
    "@types/hapi__shot": "^6.0.0",
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^1.2.0",
    "concurrently": "^8.2.2",
    "d3": "^7.9.0",
    "eslint": "^8.56.0",
    "jsdom": "^28.1.0",
    "socket.io-client": "^4.8.3",
    "supertest": "^6.3.4",
    "tsx": "^4.7.0",
    "typescript": "^5.9.3",
    "vite": "^5.0.12",
    "vitest": "^1.2.0"
  },
  "engines": {
    "node": ">=18"
  }
}
