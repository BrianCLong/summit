  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "eslint . || true"
  },
  "dependencies": {
  },
  "devDependencies": {
    "@types/express": "5.0.3",
    "@types/express-jwt": "7.4.4",
    "@types/cors": "2.8.17",
    "@types/pg": "8.11.10",
    "@types/node": "20.19.27",
    "ts-node-dev": "2.0.0",
    "typescript": "5.9.3",
    "eslint": "9.39.2",
    "@types/jsonwebtoken": "9.0.6"
  },
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
