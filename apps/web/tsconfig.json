{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": false,
    "noImplicitAny": false,
    "noImplicitThis": false,
    "forceConsistentCasingInFileNames": false,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "allowImportingTsExtensions": false,
    "typeRoots": ["./node_modules/@types", "../../node_modules/@types"],
    "types": ["node", "jest", "vite/client"]
  },
  "include": ["src", "src/**/*.json"],
  "exclude": [
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/**/*.spec.ts",
    "src/**/*.spec.tsx",
    "src/**/*.stories.ts",
    "src/**/*.stories.tsx",
    "src/**/*.e2e.ts",
    "src/**/*.e2e.tsx",
    "src/**/__tests__/**",
    "src/**/stories/**",
    "src/test-utils.tsx"
  ],
  "references": []
}
