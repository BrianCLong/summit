{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Merge Eligibility Policy",
  "type": "object",
  "required": ["version", "effective_date", "minimum_trust_score", "required_checks"],
  "properties": {
    "version": {
      "type": "string"
    },
    "effective_date": {
      "type": "string",
      "format": "date"
    },
    "minimum_trust_score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "required_checks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
