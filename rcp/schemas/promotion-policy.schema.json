{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Promotion Policy",
  "type": "object",
  "required": ["version", "effective_date", "environments"],
  "properties": {
    "version": {
      "type": "string"
    },
    "effective_date": {
      "type": "string",
      "format": "date"
    },
    "environments": {
      "type": "object",
      "patternProperties": {
        "^[a-zA-Z0-9_-]+$": {
          "type": "object",
          "required": ["minimum_trust_score", "required_attestations"],
          "properties": {
            "minimum_trust_score": {
              "type": "integer",
              "minimum": 0,
              "maximum": 100
            },
            "required_attestations": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  }
}
