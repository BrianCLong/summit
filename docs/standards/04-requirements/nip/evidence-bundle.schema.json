{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://summit.intelgraph/standards/nip/evidence-bundle.schema.json",
  "title": "Narrative CI Evidence Bundle",
  "type": "object",
  "required": [
    "task_id",
    "run_metadata",
    "artifacts",
    "gates"
  ],
  "additionalProperties": false,
  "properties": {
    "task_id": {
      "type": "string"
    },
    "run_metadata": {
      "type": "object",
      "required": [
        "stamp_file",
        "content_set_hash"
      ],
      "additionalProperties": false,
      "properties": {
        "stamp_file": {
          "type": "string",
          "const": "stamp.json"
        },
        "content_set_hash": {
          "type": "string",
          "pattern": "^[A-Fa-f0-9]{64}$"
        }
      }
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "path",
          "sha256",
          "kind"
        ],
        "additionalProperties": false,
        "properties": {
          "path": {
            "type": "string",
            "pattern": "^(?!.*\\d{4}-\\d{2}-\\d{2}).+$"
          },
          "sha256": {
            "type": "string",
            "pattern": "^[A-Fa-f0-9]{64}$"
          },
          "kind": {
            "type": "string",
            "enum": [
              "assumptions",
              "frames",
              "state_transitions",
              "test_results",
              "provenance"
            ]
          }
        }
      }
    },
    "gates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "name",
          "status"
        ],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "pass",
              "fail"
            ]
          },
          "details": {
            "type": "string"
          }
        }
      }
    }
  }
}
