{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://summit.intelgraph/standards/nip/node-edge-schema.v1.json",
  "title": "Narrative Intelligence Pipeline Node/Edge Schema",
  "type": "object",
  "required": [
    "nodes",
    "edges"
  ],
  "additionalProperties": false,
  "properties": {
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "kind",
          "confidence",
          "provenance"
        ],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9._:-]{7,127}$"
          },
          "kind": {
            "type": "string",
            "enum": [
              "Narrative",
              "Frame",
              "Claim",
              "Assumption",
              "Artifact",
              "Actor",
              "Community",
              "Event",
              "Handoff"
            ]
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "content_hash": {
            "type": "string",
            "pattern": "^[A-Fa-f0-9]{64}$"
          },
          "provenance": {
            "type": "object",
            "required": [
              "model",
              "version",
              "source_artifacts",
              "transform_chain"
            ],
            "additionalProperties": false,
            "properties": {
              "model": {
                "type": "string",
                "minLength": 1
              },
              "version": {
                "type": "string",
                "minLength": 1
              },
              "source_artifacts": {
                "type": "array",
                "items": {
                  "type": "string",
                  "pattern": "^[A-Fa-f0-9]{64}$"
                },
                "minItems": 1
              },
              "rationale_template_id": {
                "type": "string"
              },
              "transform_chain": {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": [
                    "tokenization",
                    "embedding",
                    "clustering",
                    "extraction"
                  ]
                },
                "minItems": 1
              }
            }
          }
        },
        "allOf": [
          {
            "if": {
              "properties": {
                "kind": {
                  "const": "Artifact"
                }
              }
            },
            "then": {
              "required": [
                "content_hash"
              ]
            }
          }
        ]
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "from",
          "to",
          "relation"
        ],
        "additionalProperties": false,
        "properties": {
          "from": {
            "type": "string"
          },
          "to": {
            "type": "string"
          },
          "relation": {
            "type": "string",
            "enum": [
              "EXPRESSES",
              "SUPPORTED_BY",
              "MAKES",
              "PUBLISHED",
              "AMPLIFIED",
              "COMPOSED_OF",
              "TRIGGERED_BY",
              "HANDOFF_TO",
              "DISPUTED_BY",
              "BROKEN_BY"
            ]
          }
        }
      }
    }
  }
}
