{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://summit/docs/evidence/schemas/index.schema.json",
  "title": "Evidence Index",
  "type": "object",
  "required": ["entries"],
  "additionalProperties": false,
  "properties": {
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["evidenceId", "report", "metrics", "stamp"],
        "additionalProperties": false,
        "properties": {
          "evidenceId": { "type": "string", "pattern": "^EVD-COMPANYOS-[A-Z]+-\\d{3}$" },
          "report": { "type": "string" },
          "metrics": { "type": "string" },
          "stamp": { "type": "string" }
        }
      }
    }
  }
}
