{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://summit.local/schemas/evidence/index.schema.json",
  "type": "object",
  "required": ["version", "items"],
  "properties": {
    "version": { "type": "string" },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["evidence_id", "path"],
        "properties": {
          "evidence_id": {
            "type": "string",
            "pattern": "^EVD-[a-z0-9-]+-[A-Z]+-[0-9]{3}$"
          },
          "path": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
