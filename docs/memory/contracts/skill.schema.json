{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://summit.dev/schemas/memory/skill.schema.json",
  "title": "Summit Memory Skill Contract",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "id", "title", "classification", "body"],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^1\\.[0-9]+\\.[0-9]+$"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{2,127}$"
    },
    "title": {
      "type": "string",
      "minLength": 3,
      "maxLength": 180
    },
    "classification": {
      "type": "string",
      "enum": ["public", "internal", "restricted"]
    },
    "tags": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "body": {
      "type": "string",
      "minLength": 1
    },
    "source_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
