{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://summit.dev/schemas/memory/tools.schema.json",
  "title": "Summit Memory Tools Contract",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "tier", "tools"],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^1\\.[0-9]+\\.[0-9]+$"
    },
    "tier": {
      "type": "string",
      "enum": ["agent", "user", "case", "org"]
    },
    "tools": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "kind", "allowed", "risk_level"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string",
            "enum": ["mcp", "native", "http", "shell"]
          },
          "allowed": {
            "type": "boolean"
          },
          "risk_level": {
            "type": "string",
            "enum": ["low", "medium", "high"]
          },
          "constraints": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    }
  }
}
