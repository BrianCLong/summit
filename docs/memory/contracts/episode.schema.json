{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://summit.dev/schemas/memory/episode.schema.json",
  "title": "Summit Memory Episode Event Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "episode_id",
    "event_id",
    "sequence",
    "event_type",
    "payload_hash",
    "actor",
    "tier"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^1\\.[0-9]+\\.[0-9]+$"
    },
    "episode_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{5,127}$"
    },
    "event_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{5,127}$"
    },
    "sequence": {
      "type": "integer",
      "minimum": 0
    },
    "event_type": {
      "type": "string",
      "enum": ["input", "tool_call", "tool_result", "proposal", "approval", "summary"]
    },
    "payload_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "actor": {
      "type": "string",
      "enum": ["agent", "human", "system"]
    },
    "tier": {
      "type": "string",
      "enum": ["agent", "user", "case", "org"]
    },
    "golden": {
      "type": "boolean",
      "default": false
    },
    "approved_by": {
      "type": "string"
    }
  }
}
