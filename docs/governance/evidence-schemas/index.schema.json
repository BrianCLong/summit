{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Evidence Index",
  "type": "object",
  "required": ["bundleId", "entries"],
  "properties": {
    "bundleId": { "type": "string" },
    "entries": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["files"],
        "properties": {
          "files": {
            "type": "array",
            "items": { "type": "string" }
          },
          "status": { "type": "string" },
          "notes": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
