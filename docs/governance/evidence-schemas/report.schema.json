{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Evidence Report",
  "type": "object",
  "required": ["bundleId", "summary", "evidence"],
  "properties": {
    "bundleId": { "type": "string" },
    "summary": { "type": "string" },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "status"],
        "properties": {
          "id": { "type": "string" },
          "status": { "type": "string" },
          "notes": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
