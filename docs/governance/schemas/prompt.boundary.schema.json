{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "summit.prompt.boundary.v1",
  "type": "object",
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": ["1.0.0"]
    },
    "prompt_hash": {
      "type": "string",
      "minLength": 64,
      "maxLength": 64
    },
    "template_hash": {
      "type": "string",
      "minLength": 64,
      "maxLength": 64
    },
    "untrusted_inputs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 64,
        "maxLength": 64
      }
    },
    "enforcement_method": {
      "type": "string",
      "enum": ["xml_tags", "json_schema", "markdown_blocks"]
    }
  },
  "required": [
    "schema_version",
    "prompt_hash",
    "template_hash",
    "untrusted_inputs",
    "enforcement_method"
  ],
  "additionalProperties": false
}
