{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "summit.reliability.report.v1",
  "type": "object",
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": ["1.0.0"]
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "dataset_id": {
      "type": "string"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "metrics": {
      "type": "object",
      "properties": {
        "actionability_rate": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "reproducibility_hash_match_rate": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "provable_actionability_index": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      },
      "required": [
        "actionability_rate",
        "reproducibility_hash_match_rate",
        "provable_actionability_index"
      ],
      "additionalProperties": false
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "code": { "type": "string" },
          "message": { "type": "string" },
          "count": { "type": "integer", "minimum": 1 }
        },
        "required": ["code", "message", "count"],
        "additionalProperties": false
      }
    },
    "toolchain_version": {
      "type": "string"
    }
  },
  "required": [
    "schema_version",
    "run_id",
    "metrics",
    "errors",
    "toolchain_version"
  ],
  "additionalProperties": false
}
