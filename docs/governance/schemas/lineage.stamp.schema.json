{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "summit.lineage.stamp.v1",
  "type": "object",
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": ["1.0.0"]
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "dataset_id": {
      "type": "string"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "inputs": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "hash": { "type": "string" }
        },
        "required": ["id", "hash"],
        "additionalProperties": false
      }
    },
    "outputs": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "hash": { "type": "string" }
        },
        "required": ["id", "hash"],
        "additionalProperties": false
      }
    },
    "transform_hash": {
      "type": "string"
    },
    "toolchain_version": {
      "type": "string"
    }
  },
  "required": [
    "schema_version",
    "run_id",
    "inputs",
    "outputs",
    "transform_hash",
    "toolchain_version"
  ],
  "additionalProperties": false
}
