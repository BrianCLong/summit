{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SummitWorkflow",
  "type": "object",
  "properties": {
    "goal": { "type": "string" },
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "agent": { "type": "string" },
          "action": { "type": "string" }
        },
        "required": ["agent", "action"]
      }
    }
  },
  "required": ["goal", "tasks"]
}
