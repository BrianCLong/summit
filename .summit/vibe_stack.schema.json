{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://summit.local/schemas/vibe_stack.schema.json",
  "title": "Summit Vibe Stack Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "stack",
    "allowlist",
    "constraints"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "1.0.0"
    },
    "stack": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ui",
        "api",
        "data",
        "auth",
        "observability",
        "testing",
        "deployment"
      ],
      "properties": {
        "ui": { "type": "string", "minLength": 1 },
        "api": { "type": "string", "minLength": 1 },
        "data": { "type": "string", "minLength": 1 },
        "auth": { "type": "string", "minLength": 1 },
        "observability": { "type": "string", "minLength": 1 },
        "testing": { "type": "string", "minLength": 1 },
        "deployment": { "type": "string", "minLength": 1 }
      }
    },
    "allowlist": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tools"],
      "properties": {
        "tools": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": [
              "typescript",
              "react",
              "vite",
              "jest",
              "vitest",
              "playwright",
              "graphql",
              "postgres",
              "neo4j",
              "redis",
              "opa",
              "prometheus",
              "grafana",
              "opentelemetry"
            ]
          },
          "uniqueItems": true
        }
      }
    },
    "constraints": {
      "type": "object",
      "additionalProperties": false,
      "required": ["determinism", "security"],
      "properties": {
        "determinism": {
          "type": "object",
          "additionalProperties": false,
          "required": ["disallowTimestamps", "stableOrdering"],
          "properties": {
            "disallowTimestamps": { "type": "boolean" },
            "stableOrdering": { "type": "boolean" }
          }
        },
        "security": {
          "type": "object",
          "additionalProperties": false,
          "required": ["denyByDefault", "neverLogSecrets"],
          "properties": {
            "denyByDefault": { "type": "boolean" },
            "neverLogSecrets": { "type": "boolean" }
          }
        }
      }
    }
  }
}
