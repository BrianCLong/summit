{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Agent Manifest",
  "description": "Schema for Summit AgentPlace Manifest",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "minLength": 3
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "owner": {
      "type": "string",
      "format": "email"
    },
    "description": {
      "type": "string"
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "network_access",
          "file_system",
          "system_calls"
        ]
      }
    },
    "permissions": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "read",
          "write",
          "execute",
          "admin"
        ]
      }
    },
    "data_access": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "public",
          "internal",
          "confidential",
          "pii"
        ]
      }
    }
  },
  "required": [
    "name",
    "version",
    "owner",
    "capabilities",
    "permissions",
    "data_access"
  ]
}