{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": ".",
    "strict": true,
    "composite": true,
    "typeRoots": ["../../node_modules/@types"],
    "types": ["node", "jest"]
  },
  "include": [
    "cosign/**/*.ts",
    "slsa/**/*.ts",
    "sync/**/*.ts",
    "tests/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
