{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://summit.intelgraph/governance/schema/governance.schema.json",
  "title": "Summit Governance Pack Spec",
  "type": "object",
  "required": [
    "title",
    "service_description",
    "data_classification",
    "threat_model",
    "abuse_case_fixtures"
  ],
  "additionalProperties": false,
  "properties": {
    "item_slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "title": {
      "type": "string",
      "minLength": 3
    },
    "service_description": {
      "type": "string",
      "minLength": 10
    },
    "claim_registry": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "planned_element",
          "claim_source"
        ],
        "properties": {
          "planned_element": {
            "type": "string",
            "minLength": 1
          },
          "claim_source": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "data_classification": {
      "type": "object",
      "required": [
        "pii_categories",
        "retention_policy",
        "never_log",
        "redaction_rules",
        "storage_classification"
      ],
      "additionalProperties": false,
      "properties": {
        "pii_categories": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "retention_policy": {
          "type": "string",
          "minLength": 1
        },
        "never_log": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "redaction_rules": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "storage_classification": {
          "type": "string",
          "enum": [
            "PUBLIC",
            "INTERNAL",
            "CONFIDENTIAL",
            "RESTRICTED"
          ]
        }
      }
    },
    "threat_model": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "threat",
          "mitigation",
          "ci_gate",
          "test_fixture"
        ],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^TH-[0-9]{3}$"
          },
          "threat": {
            "type": "string",
            "minLength": 3
          },
          "mitigation": {
            "type": "string",
            "minLength": 3
          },
          "ci_gate": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$"
          },
          "test_fixture": {
            "type": "string",
            "pattern": "^tests/fixtures/abuse_cases/[a-z0-9-]+/[a-z0-9._-]+$"
          }
        }
      }
    },
    "abuse_case_fixtures": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^tests/fixtures/abuse_cases/[a-z0-9-]+/[a-z0-9._-]+$"
      }
    },
    "controls": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "maestro_layers": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "Foundation",
          "Data",
          "Agents",
          "Tools",
          "Infra",
          "Observability",
          "Security"
        ]
      }
    }
  }
}
