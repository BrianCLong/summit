{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "summit.epistemic.claim",
  "title": "Epistemic Claim",
  "description": "A node in the IntelGraph representing an epistemic claim",
  "type": "object",
  "required": ["claim_id", "statement", "status", "confidence", "epistemic_uncertainty", "aleatoric_uncertainty", "domain"],
  "properties": {
    "claim_id": { "type": "string" },
    "statement": { "type": "string" },
    "status": {
      "type": "string",
      "enum": ["hypothesized", "corroborated", "refuted", "deprecated"]
    },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "epistemic_uncertainty": { "type": "number", "minimum": 0, "maximum": 1 },
    "aleatoric_uncertainty": { "type": "number", "minimum": 0, "maximum": 1 },
    "domain": { "type": "string" },
    "support_score": { "type": "number", "minimum": 0, "maximum": 1 },
    "conflict_score": { "type": "number", "minimum": 0, "maximum": 1 },
    "created_by_agent_id": { "type": "string" },
    "subject_ref": { "type": "string" }
  }
}
