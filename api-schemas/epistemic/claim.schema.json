{
  "$id": "summit.epistemic.claim",
  "type": "object",
  "required": ["claim_id", "statement", "evidence_ids", "independent_sources", "conflict_score", "support_score"],
  "properties": {
    "claim_id": { "type": "string" },
    "statement": { "type": "string" },
    "evidence_ids": { "type": "array", "items": { "type": "string" } },
    "independent_sources": { "type": "integer", "minimum": 0 },
    "conflict_score": { "type": "number", "minimum": 0, "maximum": 1 },
    "support_score": { "type": "number", "minimum": 0, "maximum": 1 }
  }
}
